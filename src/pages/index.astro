      // ── Scoring engine ──
      const THREAT_BASE = { omega: 100, high: 75, medium: 50, low: 25 };
      function scoreTitan(t, arena) {
        const pows = t.powers.map((p) => p.toLowerCase());
        // Power: threat base + bonus per extra power beyond 2
        const power =
          (THREAT_BASE[t.threat.toLowerCase()] || 25) +
          Math.max(0, (pows.length - 2) * 5);
        // Size: parse first number from height string, scale 0-100 against max 305m (Godzilla Earth)
        const hm = parseFloat(t.height) || 50;
        const size = Math.min(100, Math.round((hm / 305) * 100));
        // Resilience: powers mentioning regen/armor/endurance/immune/durability
        const regenKeywords = [
          "regenerat",
          "armor",
          "endurance",
          "immune",
          "durable",
          "shell",
          "carapace",
          "reinforce",
        ];
        const resilience = Math.min(
          100,
          30 +
            regenKeywords.reduce(
              (acc, k) => acc + (pows.some((p) => p.includes(k)) ? 18 : 0),
              0,
            ),
        );
        // Speed: supersonic/flight/mach/speed/agile
        const speedKeywords = [
          "supersonic",
          "mach",
          "flight",
          "fly",
          "speed",
          "agile",
          "quick",
          "burrowing",
          "aquatic",
        ];
        const speedScore = speedKeywords.reduce(
          (acc, k) => acc + (pows.some((p) => p.includes(k)) ? 12 : 0),
          0,
        );
        const speed = Math.min(100, 20 + speedScore);
        // Aggression: alignment mapping
        const aggMap = {
          hostile: 100,
          alpha: 82,
          unknown: 60,
          neutral: 42,
          benevolent: 25,
        };
        const aggression = aggMap[t.align] || 50;
        // Base stats object
        const stats = { power, size, resilience, speed, aggression };
        // Arena modifier
        if (arena && t.tags) {
          const boosted = t.tags.some((tag) => arena.buff.tags.includes(tag));
          if (boosted) {
            const m = arena.buff.mult;
            stats.power = Math.min(100, Math.round(stats.power * m));
            stats.speed = Math.min(100, Math.round(stats.speed * m));
            stats.resilience = Math.min(
              100,
              Math.round(stats.resilience * (1 + (m - 1) * 0.5)),
            );
          }
        }
        return stats;
      }

      // ── Power icon mapper ──
      function getPowerIcon(power) {
        const p = power.toLowerCase();
        if (
          p.includes("atomic") ||
          p.includes("nuclear") ||
          p.includes("radiation") ||
          p.includes("radioact") ||
          p.includes("thermonuclear")
