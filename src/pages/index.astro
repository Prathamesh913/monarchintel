---
import titansData from "../data/titans.json";
import moviesData from "../data/movies.json";
import episodesData from "../data/episodes.json";
import timelineData from "../data/timeline.json";
import sourcesData from "../data/sources.json";

const TMDB_KEY = import.meta.env.TMDB_API_KEY;
console.log("TMDB KEY:", TMDB_KEY ? "found" : "missing");

const delay = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

const moviesWithPosters: Array<
  (typeof moviesData)[number] & {
    poster: string | null;
    rating?: number | null;
    sources: { data: string[]; image: string[] };
  }
> = [];
for (const movie of moviesData) {
  if (!movie.tmdb_id || !TMDB_KEY) {
    moviesWithPosters.push({
      ...movie,
      poster: null,
      sources: {
        data: [
          movie.era === "monsterverse" ? "legendary" : "toho",
          "wikizilla",
        ],
        image: [],
      },
    });
    continue;
  }
  try {
    await delay(200);
    const endpoint =
      movie.type === "series"
        ? `https://api.themoviedb.org/3/tv/${movie.tmdb_id}?api_key=${TMDB_KEY}`
        : `https://api.themoviedb.org/3/movie/${movie.tmdb_id}?api_key=${TMDB_KEY}`;
    const res = await fetch(endpoint);
    const data = await res.json();
    const posterPath = data.poster_path;
    const rating = data.vote_average
      ? Math.round(data.vote_average * 10) / 10
      : null;
    console.log(
      `${movie.title}: ${posterPath ? "poster found" : "no poster"} | rating: ${rating}`,
    );
    moviesWithPosters.push({
      ...movie,
      poster: posterPath
        ? `https://image.tmdb.org/t/p/w200${posterPath}`
        : null,
      rating: rating,
      sources: {
        data: [
          movie.era === "monsterverse" ? "legendary" : "toho",
          "wikizilla",
        ],
        image: posterPath ? ["tmdb"] : [],
      },
    });
  } catch (e) {
    console.log(`${movie.title}: fetch error - ${e.message}`);
    moviesWithPosters.push({
      ...movie,
      poster: null,
      sources: {
        data: [
          movie.era === "monsterverse" ? "legendary" : "toho",
          "wikizilla",
        ],
        image: [],
      },
    });
  }
}

type EpisodeWithStill = (typeof episodesData)[number]["episodes"][number] & {
  still: string | null;
  air: string;
};
type ShowWithStills = (typeof episodesData)[number] & {
  episodes: EpisodeWithStill[];
  sources: { data: string[]; image: string[] };
};

const episodesWithStills: ShowWithStills[] = [];
for (const show of episodesData) {
  // Fetch full season from TMDB once (instead of one call per episode)
  const tmdbEpMap = new Map<number, any>();
  if ("tmdb_id" in show && show.tmdb_id && TMDB_KEY) {
    try {
      await delay(300);
      const seasonNum = "season" in show ? show.season : 1;
      const url = `https://api.themoviedb.org/3/tv/${show.tmdb_id}/season/${seasonNum}?api_key=${TMDB_KEY}`;
      const res = await fetch(url);
      const data = await res.json();
      if (Array.isArray(data.episodes)) {
        for (const ep of data.episodes) tmdbEpMap.set(ep.episode_number, ep);
        console.log(
          `${show.title}: fetched ${tmdbEpMap.size} episodes from TMDB`,
        );
      }
    } catch (e) {
      console.log(`${show.title}: season fetch error - ${e.message}`);
    }
  }

  const formatDate = (raw: string) =>
    new Date(raw).toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    });

  const enrichedEps: EpisodeWithStill[] = [];
  const jsonNums = new Set(show.episodes.map((ep) => ep.num));

  // Enrich existing JSON episodes with live TMDB air date + still
  for (const ep of show.episodes) {
    const t = tmdbEpMap.get(ep.num);
    enrichedEps.push({
      ...ep,
      air: t?.air_date ? formatDate(t.air_date) : ep.air,
      still: t?.still_path
        ? `https://image.tmdb.org/t/p/w300${t.still_path}`
        : null,
    });
  }

  // Auto-add any TMDB episodes not yet in episodes.json
  for (const [epNum, t] of tmdbEpMap) {
    if (!jsonNums.has(epNum)) {
      console.log(`${show.title}: auto-adding E${epNum} "${t.name}" from TMDB`);
      enrichedEps.push({
        num: epNum,
        title: t.name || `Episode ${epNum}`,
        air: t.air_date ? formatDate(t.air_date) : "TBA",
        titans: [],
        synopsis: t.overview || "Synopsis not yet available.",
        still: t.still_path
          ? `https://image.tmdb.org/t/p/w300${t.still_path}`
          : null,
      });
    }
  }

  enrichedEps.sort((a, b) => a.num - b.num);
  episodesWithStills.push({
    ...show,
    episodes: enrichedEps,
    sources: {
      data: [
        show.platform === "Apple TV+"
          ? "apple_tv"
          : show.platform === "Netflix"
            ? "netflix"
            : "toho",
        "wikizilla",
      ],
      image: ["tmdb"],
    },
  });
}

const titansJSON = JSON.stringify(titansData);
const moviesJSON = JSON.stringify(moviesWithPosters);
const episodesJSON = JSON.stringify(episodesWithStills);
const timelineJSON = JSON.stringify(timelineData);
const sourcesJSON = JSON.stringify(sourcesData);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MonarchIntel — MonsterVerse Titan Intelligence Archive</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* ═══════════════════════════════════════
   MONARCHINTEL — COMPLETE DESIGN SYSTEM
═══════════════════════════════════════ */
      :root {
        --void: #020608;
        --deep: #040a0e;
        --surface: #091318;
        --surface-2: #0c1a24;
        --surface-3: #0f2030;
        --border: #152535;
        --border-2: #1e3a55;
        --border-3: #2a5070;
        --text: #c0d8e8;
        --text-2: #7a9ab0;
        --muted: #4a6878;
        --inverse: #040a0e;
        --nuclear: #00ff88;
        --nuclear-2: #00cc66;
        --nuclear-glow: rgba(0, 255, 136, 0.12);
        --monarch: #e8b400;
        --monarch-2: #a07800;
        --sky: #00aaff;
        --alive: #00ff88;
        --dormant: #e8b400;
        --deceased: #4a6878;
        --unknown: #00aaff;
        --threat-low: #00ff88;
        --threat-med: #ffaa00;
        --threat-high: #ff6600;
        --threat-omega: #ff0055;
        --alpha: #ff4444;
        --hostile: #ff4d00;
        --benevolent: #00ff88;
        --neutral: #4a6878;
        --era-mv: #0099ff;
        --era-showa: #ff88aa;
        --era-heisei: #e8b400;
        --era-millennium: #aa44ff;
        --era-reiwa: #00ff88;
        --era-animation: #00ccff;
        --paper: #f0e8d0;
        --paper-2: #e8dfc4;
        --ink: #1a1008;
        --stamp-red: #8b1a1a;
        --stamp-blue: #0a2a5e;
        --font-display: "Bebas Neue", sans-serif;
        --font-serif: "DM Serif Display", serif;
        --font-ui: "Rajdhani", sans-serif;
        --font-mono: "Share Tech Mono", monospace;
        --font-doc: "Special Elite", monospace;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        background: var(--deep);
        color: var(--text);
        font-family: var(--font-ui);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 3px,
          rgba(0, 0, 0, 0.015) 3px,
          rgba(0, 0, 0, 0.015) 4px
        );
      }
      ::selection {
        background: rgba(0, 255, 136, 0.22);
        color: #fff;
      }
      ::-webkit-scrollbar {
        width: 5px;
        height: 5px;
      }
      ::-webkit-scrollbar-track {
        background: var(--void);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--border-2);
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--nuclear);
      }

      /* ── MASTHEAD ── */
      .masthead {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        height: 58px;
        background: rgba(2, 6, 8, 0.97);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        padding: 0 1.5rem;
        gap: 0;
      }
      .mast-brand {
        display: flex;
        flex-direction: column;
        margin-right: 2rem;
        cursor: pointer;
        flex-shrink: 0;
      }
      .mast-name {
        font-family: var(--font-display);
        font-size: 1.5rem;
        letter-spacing: 4px;
        line-height: 1;
      }
      .mast-name .mo {
        color: var(--nuclear);
        text-shadow: 0 0 15px rgba(0, 255, 136, 0.3);
      }
      .mast-name .in {
        color: #fff;
      }
      .mast-sub {
        font-family: var(--font-mono);
        font-size: 0.46rem;
        color: var(--muted);
        letter-spacing: 3px;
        margin-top: 1px;
      }
      .mast-nav {
        display: flex;
        gap: 0;
        overflow-x: auto;
      }
      .mast-nav::-webkit-scrollbar {
        display: none;
      }
      .mnav {
        height: 58px;
        padding: 0 0.95rem;
        background: none;
        border: none;
        color: var(--muted);
        font-family: var(--font-ui);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        white-space: nowrap;
        transition: all 0.2s;
      }
      .mnav:hover,
      .mnav.on {
        color: var(--nuclear);
        border-bottom-color: var(--nuclear);
      }
      .mnav:active {
        opacity: 0.65;
        transition: opacity 0.1s;
      }
      .mast-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-shrink: 0;
      }
      .mast-tag {
        font-family: var(--font-mono);
        font-size: 0.52rem;
        color: var(--monarch);
        border: 1px solid var(--monarch-2);
        padding: 0.22rem 0.6rem;
        letter-spacing: 2px;
        animation: blinktag 4s infinite;
      }
      @keyframes blinktag {
        0%,
        90%,
        100% {
          opacity: 1;
        }
        95% {
          opacity: 0.4;
        }
      }

      /* ── INTEL TICKER ── */
      .ticker {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        overflow: hidden;
        height: 34px;
        display: flex;
        align-items: center;
        position: fixed;
        top: 58px;
        left: 0;
        right: 0;
        z-index: 999;
      }
      .ticker-tag {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        background: var(--nuclear);
        color: var(--inverse);
        padding: 0 1rem;
        height: 100%;
        display: flex;
        align-items: center;
        letter-spacing: 3px;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .ticker-track {
        flex: 1;
        overflow: hidden;
        position: relative;
        height: 100%;
      }
      .ticker-inner {
        display: flex;
        align-items: center;
        height: 100%;
        gap: 3rem;
        animation: tickscroll 40s linear infinite;
        width: max-content;
        padding-left: 2rem;
      }
      @keyframes tickscroll {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      .ticker-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        white-space: nowrap;
      }
      .ticker-dot {
        width: 4px;
        height: 4px;
        background: var(--nuclear);
        flex-shrink: 0;
      }
      .ticker-text {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--text-2);
        letter-spacing: 1px;
      }

      /* ── PAGES ── */
      .page {
        display: none;
        padding-top: 96px;
      }
      .page.on {
        display: block;
      }

      /* ── HERO ── */
      .hero {
        min-height: calc(100vh - 58px);
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 5rem;
        align-items: center;
        max-width: 1400px;
        margin: 0 auto;
        padding: 5rem 2rem;
        position: relative;
      }
      @media (max-width: 1000px) {
        .hero {
          grid-template-columns: 1fr;
          padding: 3rem 1.5rem;
        }
      }
      .hero-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background:
          radial-gradient(
            ellipse 60% 50% at 25% 50%,
            rgba(0, 255, 136, 0.04),
            transparent 65%
          ),
          radial-gradient(
            ellipse 40% 60% at 75% 30%,
            rgba(0, 170, 255, 0.035),
            transparent 65%
          ),
          radial-gradient(
            ellipse 35% 45% at 60% 80%,
            rgba(255, 77, 0, 0.03),
            transparent 60%
          );
      }
      .hero-grid-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background-image:
          linear-gradient(rgba(0, 255, 136, 0.018) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 255, 136, 0.018) 1px, transparent 1px);
        background-size: 100px 100px;
        animation: gridflow 35s linear infinite;
      }
      @keyframes gridflow {
        0% {
          transform: translateY(0);
        }
        100% {
          transform: translateY(100px);
        }
      }
      .hero-accent-line {
        position: fixed;
        left: 0;
        top: 58px;
        bottom: 0;
        width: 3px;
        background: linear-gradient(
          to bottom,
          transparent,
          var(--nuclear) 20%,
          var(--nuclear) 80%,
          transparent
        );
        opacity: 0.3;
        pointer-events: none;
        z-index: 0;
      }
      .hero-left {
        position: relative;
        z-index: 1;
      }
      .hero-eye {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--nuclear);
        letter-spacing: 5px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.7rem;
        opacity: 0;
        animation: fadeup 0.4s 0.15s cubic-bezier(0, 0, 0.2, 1) forwards;
      }
      .hero-eye::before {
        content: "";
        width: 28px;
        height: 1px;
        background: var(--nuclear);
      }
      .hero-title {
        font-family: var(--font-display);
        line-height: 0.88;
        letter-spacing: -1px;
        margin-bottom: 1.2rem;
        opacity: 0;
        animation: fadeup 0.4s 0.25s cubic-bezier(0, 0, 0.2, 1) forwards;
      }
      .hero-title .l1 {
        font-size: clamp(4rem, 10vw, 9rem);
        background: linear-gradient(155deg, #fff 0%, #8bbdd4 55%, #2a6080 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
        text-wrap: balance;
      }
      .hero-title .l2 {
        font-size: clamp(4rem, 10vw, 9rem);
        background: linear-gradient(
          155deg,
          var(--nuclear) 0%,
          var(--nuclear-2) 55%,
          #004433 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
        filter: drop-shadow(0 0 30px rgba(0, 255, 136, 0.18));
        text-wrap: balance;
      }
      .hero-deck {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 1.2rem;
        color: var(--text-2);
        line-height: 1.7;
        max-width: 540px;
        margin-bottom: 2.5rem;
        opacity: 0;
        animation: fadeup 0.4s 0.35s cubic-bezier(0, 0, 0.2, 1) forwards;
        text-wrap: pretty;
      }
      .hero-counters {
        display: flex;
        gap: 2.5rem;
        margin-bottom: 2.5rem;
        opacity: 0;
        animation: fadeup 0.4s 0.45s cubic-bezier(0, 0, 0.2, 1) forwards;
        flex-wrap: wrap;
      }
      .hcounter {
      }
      .hcn {
        font-family: var(--font-display);
        font-size: 2.8rem;
        color: var(--nuclear);
        line-height: 1;
        text-shadow: 0 0 20px rgba(0, 255, 136, 0.25);
        display: block;
        font-variant-numeric: tabular-nums;
      }
      .hcl {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--muted);
        letter-spacing: 3px;
        margin-top: 0.1rem;
        display: block;
      }
      .hero-btns {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
        opacity: 0;
        animation: fadeup 0.4s 0.55s cubic-bezier(0, 0, 0.2, 1) forwards;
      }
      @keyframes fadeup {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* Featured Titan */
      .feat-titan {
        position: relative;
        z-index: 1;
        background: var(--surface);
        border: 1px solid var(--border-2);
        overflow: hidden;
        opacity: 0;
        animation: fadeup 0.4s 0.4s cubic-bezier(0, 0, 0.2, 1) forwards;
      }
      .feat-titan::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--nuclear),
          transparent
        );
      }
      .ft-head {
        background: linear-gradient(
          135deg,
          rgba(0, 255, 136, 0.07),
          rgba(0, 170, 255, 0.04)
        );
        border-bottom: 1px solid var(--border);
        padding: 0.9rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .ft-head-lbl {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--nuclear);
        letter-spacing: 3px;
      }
      .ft-head-date {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--muted);
        letter-spacing: 2px;
      }
      .ft-body {
        padding: 1.5rem;
      }
      .ft-emoji {
        font-size: 5.5rem;
        display: block;
        text-align: center;
        margin: 0.5rem 0 1rem;
        filter: drop-shadow(0 6px 20px rgba(0, 0, 0, 0.5));
        animation: floatfeat 5s ease-in-out infinite;
      }
      @keyframes floatfeat {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-9px);
        }
      }
      .ft-name {
        font-family: var(--font-display);
        font-size: 2.8rem;
        color: #fff;
        letter-spacing: 3px;
        line-height: 1;
      }
      .ft-alias {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--muted);
        letter-spacing: 2px;
        margin-top: 0.25rem;
      }
      .ft-pull {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.92rem;
        color: var(--text-2);
        line-height: 1.7;
        margin: 1rem 0;
        padding: 0.8rem 1rem;
        border-left: 2px solid var(--nuclear);
        background: rgba(0, 255, 136, 0.03);
        text-wrap: pretty;
      }
      .ft-pull-attr {
        font-family: var(--font-mono);
        font-size: 0.52rem;
        color: var(--muted);
        letter-spacing: 2px;
        margin-top: 0.4rem;
        font-style: normal;
      }
      .ft-badges {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        margin-top: 1rem;
      }
      .ft-foot {
        border-top: 1px solid var(--border);
        padding: 0.75rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .ft-foot-data {
        font-family: var(--font-mono);
        font-size: 0.55rem;
        color: var(--muted);
        letter-spacing: 1px;
      }
      .ft-cta {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--nuclear);
        letter-spacing: 2px;
        cursor: pointer;
        transition: opacity 0.2s;
      }
      .ft-cta:hover {
        opacity: 0.7;
      }

      /* ── BUTTONS ── */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-display);
        letter-spacing: 3px;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
        font-size: 1rem;
      }
      .btn-p {
        background: var(--nuclear);
        color: var(--inverse);
        padding: 0.82rem 2.2rem;
        clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
      }
      .btn-p:hover {
        background: #fff;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 255, 136, 0.2);
      }
      .btn-p:active {
        background: var(--nuclear-2);
        transform: translateY(0) scale(0.97);
        transition:
          transform 0.08s,
          background 0.08s;
      }
      .btn-s {
        background: transparent;
        color: var(--text);
        border: 1px solid var(--border-2) !important;
        padding: 0.82rem 2.2rem;
        clip-path: none;
      }
      .btn-s:hover {
        border-color: var(--nuclear) !important;
        color: var(--nuclear);
      }
      .btn-s:active,
      .btn-g:active {
        transform: scale(0.97);
        opacity: 0.8;
        transition:
          transform 0.08s,
          opacity 0.08s;
      }
      .btn-g {
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--border) !important;
        padding: 0.65rem 1.4rem;
        font-family: var(--font-mono);
        letter-spacing: 2px;
        font-size: 0.7rem;
        clip-path: none;
      }
      .btn-g:hover {
        border-color: var(--nuclear) !important;
        color: var(--nuclear);
      }

      /* ── BADGES ── */
      .badge {
        display: inline-flex;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 0.58rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 0.18rem 0.6rem;
        border: 1px solid;
        line-height: 1.5;
      }
      .b-nuc {
        border-color: var(--nuclear);
        color: var(--nuclear);
        background: rgba(0, 255, 136, 0.07);
      }
      .b-mon {
        border-color: var(--monarch);
        color: var(--monarch);
        background: rgba(232, 180, 0, 0.07);
      }
      .b-sky {
        border-color: var(--sky);
        color: var(--sky);
        background: rgba(0, 170, 255, 0.07);
      }
      .b-lava {
        border-color: var(--hostile);
        color: var(--hostile);
        background: rgba(255, 77, 0, 0.07);
      }
      .b-mut {
        border-color: var(--border-2);
        color: var(--muted);
      }
      .b-omg {
        border-color: var(--threat-omega);
        color: var(--threat-omega);
        background: rgba(255, 0, 85, 0.07);
        animation: omg 2s infinite;
      }
      @keyframes omg {
        0%,
        100% {
          box-shadow: 0 0 0 rgba(255, 0, 85, 0);
        }
        50% {
          box-shadow: 0 0 10px rgba(255, 0, 85, 0.35);
        }
      }
      .b-sm {
        font-size: 0.52rem;
        padding: 0.12rem 0.45rem;
      }
      .b-lg {
        font-size: 0.65rem;
        padding: 0.28rem 0.85rem;
      }

      /* ── SECTION COMMON ── */
      .sec {
        max-width: 1400px;
        margin: 0 auto;
        padding: 4.5rem 2rem;
      }
      .sec-head {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
        flex-wrap: wrap;
      }
      .sec-title {
        font-family: var(--font-display);
        font-size: 2.2rem;
        color: #fff;
        letter-spacing: 2px;
        text-wrap: balance;
      }
      .sec-code {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--nuclear);
        letter-spacing: 3px;
      }
      .sec-count {
        margin-left: auto;
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }
      .sec-deck {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 1.05rem;
        color: var(--text-2);
        line-height: 1.7;
        margin-bottom: 2rem;
        max-width: 700px;
        text-wrap: pretty;
      }
      .divider {
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--border-2),
          transparent
        );
        margin: 0 2rem;
      }

      /* ── CONTROLS ── */
      .ctrl {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        flex-wrap: wrap;
        align-items: center;
      }
      .tog {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--muted);
        padding: 0.55rem 1rem;
        font-family: var(--font-ui);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
      }
      .tog:hover,
      .tog.on {
        background: rgba(0, 255, 136, 0.07);
        border-color: var(--nuclear);
        color: var(--nuclear);
      }
      .tog.mon:hover,
      .tog.mon.on {
        background: rgba(232, 180, 0, 0.07);
        border-color: var(--monarch);
        color: var(--monarch);
      }
      .tog:active {
        transform: scale(0.96);
        transition: transform 0.08s;
      }
      .srchwrap {
        position: relative;
        flex: 1;
        min-width: 180px;
      }
      .srchwrap::before {
        content: "⌕";
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        font-size: 1rem;
        pointer-events: none;
      }
      .srch {
        width: 100%;
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 0.42rem 0.9rem 0.42rem 2.1rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 1px;
        outline: none;
        transition: border-color 0.2s;
      }
      .srch::placeholder {
        color: var(--muted);
        letter-spacing: 1px;
        opacity: 1;
      }
      .srch:focus {
        border-color: var(--nuclear);
        background: var(--surface-3);
      }
      .fsel {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 0.42rem 0.9rem;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 1px;
        outline: none;
        cursor: pointer;
      }
      .fsel:focus {
        border-color: var(--nuclear);
      }

      /* ── CONTENT GRID (HOME) ── */
      .home-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1px;
        background: var(--border);
      }
      @media (max-width: 900px) {
        .home-grid {
          grid-template-columns: 1fr;
        }
      }
      .hg-item {
        background: var(--void);
        padding: 2.5rem;
        transition: background 0.2s;
        cursor: pointer;
        position: relative;
        overflow: hidden;
      }
      .hg-item::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--item-color, var(--nuclear)),
          transparent
        );
        opacity: 0;
        transition: opacity 0.2s;
      }
      .hg-item:hover {
        background: var(--surface);
      }
      .hg-item:hover::after {
        opacity: 1;
      }
      .hg-num {
        font-family: var(--font-display);
        font-size: 4.5rem;
        color: var(--border-2);
        line-height: 1;
        margin-bottom: 1rem;
        transition: color 0.2s;
        display: block;
      }
      .hg-item:hover .hg-num {
        color: var(--nuclear);
        text-shadow: 0 0 20px rgba(0, 255, 136, 0.2);
      }
      .hg-title {
        font-family: var(--font-display);
        font-size: 1.6rem;
        color: #fff;
        letter-spacing: 2px;
        margin-bottom: 0.5rem;
      }
      .hg-deck {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.92rem;
        color: var(--text-2);
        line-height: 1.65;
        margin-bottom: 1rem;
      }
      .hg-meta {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--muted);
        letter-spacing: 2px;
      }
      .hg-wide {
        grid-column: 1/-1;
        background: linear-gradient(
          135deg,
          rgba(0, 255, 136, 0.04),
          rgba(0, 170, 255, 0.03)
        );
        border-top: 1px solid var(--border);
      }

      /* ── TITAN MINI STRIP ── */
      .tmini-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1px;
        background: var(--border);
      }
      .tmini {
        background: var(--surface);
        padding: 1.1rem;
        cursor: pointer;
        transition: all 0.2s;
        border-top: 2px solid transparent;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }
      .tmini:hover {
        background: var(--surface-2);
        border-top-color: var(--nuclear);
      }
      .tmini-e {
        font-size: 1.8rem;
      }
      .tmini-n {
        font-family: var(--font-display);
        font-size: 1.1rem;
        color: #fff;
        letter-spacing: 2px;
        line-height: 1;
      }
      .tmini-s {
        font-family: var(--font-mono);
        font-size: 0.52rem;
        color: var(--muted);
        letter-spacing: 2px;
      }
      .tmini-more {
        align-items: center;
        justify-content: center;
        border-top-color: transparent !important;
      }
      .tmini-more:hover {
        border-top-color: var(--nuclear) !important;
      }

      /* ── WATCH ORDER ── */
      .wo-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .wo-item {
        display: grid;
        grid-template-columns: 52px 80px 1fr 80px;
        gap: 1.5rem;
        align-items: start;
        padding: 1.8rem 1.5rem;
        background: var(--surface);
        border: 1px solid transparent;
        border-left: 3px solid transparent;
        cursor: pointer;
        transition: all 0.2s;
      }
      .wo-item:hover {
        background: var(--surface-2);
        border-color: var(--border);
        border-left-color: var(--nuclear);
      }
      .wo-item.open {
        background: var(--surface-2);
        border-color: var(--border);
        border-left-color: var(--nuclear);
      }
      .wo-num {
        font-family: var(--font-display);
        font-size: 1.6rem;
        color: var(--border-2);
        text-align: center;
        transition: all 0.2s;
        padding-top: 0.15rem;
        font-variant-numeric: tabular-nums;
      }
      .wo-item:hover .wo-num,
      .wo-item.open .wo-num {
        color: var(--nuclear);
        text-shadow: 0 0 12px var(--nuclear);
      }
      .wo-icon {
        width: 70px;
        height: 104px;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        overflow: hidden;
        flex-shrink: 0;
      }
      .wo-icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .wo-body {
        min-width: 0;
        position: relative;
      }
      .wo-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.5px;
        margin-bottom: 0.5rem;
      }
      .wo-meta {
        display: flex;
        gap: 0.9rem;
        margin-top: 0.22rem;
        margin-bottom: 0.55rem;
        align-items: center;
        flex-wrap: wrap;
      }
      .wo-year {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--muted);
      }
      .epill {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        letter-spacing: 2px;
        padding: 0.18rem 0.65rem;
        border: 1px solid;
        text-transform: uppercase;
      }
      .e-mv {
        border-color: var(--era-mv);
        color: var(--era-mv);
      }
      .e-showa {
        border-color: var(--era-showa);
        color: var(--era-showa);
      }
      .e-heisei {
        border-color: var(--era-heisei);
        color: var(--era-heisei);
      }
      .e-millennium {
        border-color: var(--era-millennium);
        color: var(--era-millennium);
      }
      .e-reiwa {
        border-color: var(--era-reiwa);
        color: var(--era-reiwa);
      }
      .e-animation {
        border-color: var(--era-animation);
        color: var(--era-animation);
      }
      .wo-chips {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        margin-top: 0.4rem;
      }
      .wo-chip {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        background: rgba(0, 255, 136, 0.06);
        border: 1px solid rgba(0, 255, 136, 0.16);
        color: var(--nuclear);
        padding: 0.18rem 0.55rem;
      }
      .wo-right {
        text-align: right;
        padding-top: 0.15rem;
      }
      .wo-score {
        font-family: var(--font-display);
        font-size: 1.4rem;
        color: var(--monarch);
        line-height: 1;
        font-variant-numeric: tabular-nums;
      }
      .wo-plat {
        font-family: var(--font-mono);
        font-size: 0.56rem;
        color: var(--muted);
        margin-top: 0.15rem;
      }
      .wo-expand {
        display: none;
        grid-column: 1/-1;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
        margin-top: 0.5rem;
      }
      .wo-expand.show {
        display: block;
      }
      .wo-exp-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
        gap: 0.7rem;
        margin-bottom: 0.8rem;
      }
      .wo-ef label {
        font-family: var(--font-mono);
        font-size: 0.56rem;
        color: var(--muted);
        letter-spacing: 2px;
        display: block;
        margin-bottom: 0.15rem;
      }
      .wo-ef span {
        font-size: 0.88rem;
        font-weight: 600;
      }
      .wo-syn {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.92rem;
        color: var(--text-2);
        line-height: 1.7;
        text-wrap: pretty;
      }

      /* ── TITANDEX ── */
      .tdex-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1px;
        background: var(--border);
      }
      .tcard {
        background: var(--surface);
        border: 1px solid transparent;
        padding: 1.4rem;
        cursor: pointer;
        transition: all 0.25s;
        position: relative;
        overflow: hidden;
      }
      .tcard::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--ca, var(--nuclear)),
          transparent
        );
        opacity: 0;
        transition: opacity 0.2s;
      }
      .tcard:hover {
        background: var(--surface-2);
        border-color: var(--border-2);
        transform: translateY(-2px);
        box-shadow:
          0 2px 4px rgba(2, 6, 20, 0.3),
          0 8px 20px rgba(2, 6, 20, 0.35),
          0 12px 32px rgba(0, 255, 136, 0.05);
      }
      .tcard:hover::before {
        opacity: 1;
      }
      .tcard:active {
        transform: translateY(0) scale(0.98);
        transition: transform 0.08s;
      }
      .tcard[data-a="alpha"] {
        --ca: var(--alpha);
      }
      .tcard[data-a="hostile"] {
        --ca: var(--hostile);
      }
      .tcard[data-a="benevolent"] {
        --ca: var(--benevolent);
      }
      .tcard[data-a="neutral"] {
        --ca: var(--neutral);
      }
      .tcard[data-a="unknown"] {
        --ca: var(--sky);
      }
      /* Omega threat card-level pulse */
      .tcard[data-threat="omega"] {
        animation: omg-card 3s ease-in-out infinite;
      }
      @keyframes omg-card {
        0%,
        100% {
          box-shadow: 0 0 0 rgba(255, 0, 85, 0);
        }
        50% {
          box-shadow:
            0 0 18px rgba(255, 0, 85, 0.18),
            inset 0 0 8px rgba(255, 0, 85, 0.03);
        }
      }
      .tc-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.6rem;
      }
      .tc-id {
        font-family: var(--font-mono);
        font-size: 0.56rem;
        color: var(--muted);
        letter-spacing: 2px;
      }
      .tc-emoji {
        font-size: 2.6rem;
        margin: 0.4rem 0;
        line-height: 1;
        filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.5));
      }
      .tc-name {
        font-family: var(--font-display);
        font-size: 1.5rem;
        color: #fff;
        letter-spacing: 2px;
        line-height: 1;
      }
      .tc-alias {
        font-family: var(--font-mono);
        font-size: 0.56rem;
        color: var(--muted);
        letter-spacing: 1px;
        margin-top: 0.15rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .tc-div {
        height: 1px;
        background: var(--border);
        margin: 0.85rem 0;
      }
      .tc-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.45rem;
      }
      .tcs label {
        font-family: var(--font-mono);
        font-size: 0.5rem;
        color: var(--muted);
        letter-spacing: 2px;
        display: block;
      }
      .tcs span {
        font-size: 0.8rem;
        font-weight: 700;
      }
      .al-alpha {
        color: var(--alpha);
      }
      .al-hostile {
        color: var(--hostile);
      }
      .al-benevolent {
        color: var(--benevolent);
      }
      .al-neutral {
        color: var(--neutral);
      }
      .al-unknown {
        color: var(--sky);
      }
      .st-alive {
        color: var(--alive);
      }
      .st-dormant {
        color: var(--dormant);
      }
      .st-deceased {
        color: var(--deceased);
      }
      .st-unknown {
        color: var(--unknown);
      }
      .tl-low {
        border-color: var(--threat-low);
        color: var(--threat-low);
      }
      .tl-medium {
        border-color: var(--threat-med);
        color: var(--threat-med);
      }
      .tl-high {
        border-color: var(--threat-high);
        color: var(--threat-high);
      }
      .tl-omega {
        border-color: var(--threat-omega);
        color: var(--threat-omega);
        animation: omg 2s infinite;
      }
      .tc-pbar {
        display: flex;
        gap: 2px;
        margin-top: 0.8rem;
      }
      .tcpb {
        height: 3px;
        flex: 1;
        background: var(--border);
      }
      .tcpb.on {
        background: var(--nuclear);
        box-shadow: 0 0 4px var(--nuclear);
      }
      .tc-hint {
        font-family: var(--font-mono);
        font-size: 0.52rem;
        color: var(--muted);
        letter-spacing: 2px;
        margin-top: 0.7rem;
        text-align: center;
        opacity: 0;
        transition: opacity 0.2s;
      }
      .tcard:hover .tc-hint {
        opacity: 1;
      }

      /* ── MODAL ── */
      .moverlay {
        position: fixed;
        inset: 0;
        background: rgba(2, 6, 8, 0.96);
        z-index: 3000;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        backdrop-filter: blur(8px);
      }
      .moverlay.open {
        display: flex;
        animation: mopen 0.25s ease;
      }
      @keyframes mopen {
        from {
          opacity: 0;
          transform: scale(0.96);
        }
        to {
          opacity: 1;
          transform: scale(1);
        }
      }
      .modal {
        background: var(--surface);
        border: 1px solid var(--border-2);
        width: 100%;
        max-width: 880px;
        max-height: 92vh;
        overflow-y: auto;
        overflow-x: hidden;
      }
      .mhd {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        padding: 1.5rem;
        background: var(--surface-2);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 20;
      }
      .mhd-info {
        flex: 1;
      }
      .mid-lbl {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--muted);
        letter-spacing: 3px;
        margin-bottom: 0.25rem;
      }
      .mhd-name {
        font-family: var(--font-display);
        font-size: 2.2rem;
        color: #fff;
        letter-spacing: 3px;
        line-height: 1;
      }
      .mhd-alias {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--muted);
        letter-spacing: 2px;
        margin-top: 0.2rem;
      }
      .mclose {
        background: none;
        border: 1px solid var(--border);
        color: var(--muted);
        width: 34px;
        height: 34px;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .mclose:hover {
        border-color: var(--hostile);
        color: var(--hostile);
      }
      .mclose:active {
        transform: scale(0.9);
        transition: transform 0.08s;
      }
      .mbody {
        padding: 1.5rem;
        display: grid;
        grid-template-columns: 190px 1fr;
        gap: 1.5rem;
      }
      @media (max-width: 600px) {
        .mbody {
          grid-template-columns: 1fr;
        }
      }
      .mdisp {
        background: var(--deep);
        border: 1px solid var(--border);
        padding: 1.5rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }
      .memoji {
        font-size: 5rem;
        filter: drop-shadow(0 0 20px rgba(0, 255, 136, 0.12));
        animation: floatfeat 4s ease-in-out infinite;
      }
      .mright {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
      }
      .mstats {
        background: var(--deep);
        border: 1px solid var(--border);
        padding: 1rem;
      }
      .msr {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
        gap: 1rem;
      }
      .msr:last-child {
        border-bottom: none;
      }
      .msr label {
        font-family: var(--font-mono);
        font-size: 0.56rem;
        color: var(--muted);
        letter-spacing: 2px;
        text-transform: uppercase;
        flex-shrink: 0;
      }
      .msr .v {
        font-size: 0.88rem;
        font-weight: 600;
        text-align: right;
      }
      .mblock {
        background: var(--deep);
        border: 1px solid var(--border);
        padding: 1rem;
        grid-column: 1/-1;
      }
      .mblock-t {
        font-family: var(--font-display);
        font-size: 1rem;
        letter-spacing: 3px;
        color: var(--nuclear);
        margin-bottom: 0.7rem;
      }
      .mtags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
      }
      .ptag {
        background: rgba(0, 255, 136, 0.06);
        border: 1px solid rgba(0, 255, 136, 0.18);
        color: var(--nuclear);
        font-family: var(--font-mono);
        font-size: 0.58rem;
        letter-spacing: 1px;
        padding: 0.22rem 0.65rem;
      }
      .atag {
        background: rgba(232, 180, 0, 0.06);
        border: 1px solid rgba(232, 180, 0, 0.18);
        color: var(--monarch);
        font-family: var(--font-mono);
        font-size: 0.58rem;
        letter-spacing: 1px;
        padding: 0.22rem 0.65rem;
      }

      /* ── EPISODES ── */
      .show-tabs {
        display: flex;
        gap: 0;
        border-bottom: 1px solid var(--border);
        margin-bottom: 1.5rem;
        overflow-x: auto;
      }
      .show-tabs::-webkit-scrollbar {
        display: none;
      }
      .stab {
        background: none;
        border: none;
        color: var(--muted);
        font-family: var(--font-ui);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 0.8rem 1.5rem;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        white-space: nowrap;
        transition: all 0.2s;
      }
      .stab:hover,
      .stab.on {
        color: var(--nuclear);
        border-bottom-color: var(--nuclear);
      }
      .ep-list {
        display: flex;
        flex-direction: column;
        gap: 1px;
      }
      .ep-item {
        display: grid;
        grid-template-columns: 50px 160px 1fr 40px;
        gap: 1rem;
        align-items: start;
        padding: 1rem 1.2rem;
        background: var(--surface);
        border: 1px solid transparent;
        border-left: 3px solid transparent;
        cursor: pointer;
        transition: all 0.2s;
      }
      .ep-still {
        width: 160px;
        min-width: 160px;
        max-width: 160px;
        height: 90px;
        max-height: 90px;
        border: 1px solid var(--border);
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        background: var(--deep);
        flex-shrink: 0;
      }
      .ep-still img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        flex-shrink: 0;
      }
      .ep-item:hover {
        background: var(--surface-2);
        border-color: var(--border);
        border-left-color: var(--monarch);
      }
      .ep-item.open {
        background: var(--surface-2);
        border-left-color: var(--monarch);
        border-color: var(--border);
      }
      .ep-num {
        font-family: var(--font-display);
        font-size: 1.5rem;
        color: var(--border-2);
        text-align: center;
        transition: color 0.2s;
        font-variant-numeric: tabular-nums;
      }
      .ep-item:hover .ep-num,
      .ep-item.open .ep-num {
        color: var(--monarch);
      }
      .ep-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: 0.5px;
        margin-bottom: 0.5rem;
      }
      .ep-air {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--muted);
        letter-spacing: 2px;
        margin-top: 0.2rem;
        font-variant-numeric: tabular-nums;
      }
      .ep-titans {
        display: flex;
        gap: 0.3rem;
        flex-wrap: wrap;
        margin-top: 0.35rem;
      }
      .ep-tag {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        letter-spacing: 2px;
        background: rgba(232, 180, 0, 0.06);
        border: 1px solid rgba(232, 180, 0, 0.18);
        color: var(--monarch);
        padding: 0.18rem 0.55rem;
      }
      .ep-expand {
        display: none;
        grid-column: 1/-1;
        border-top: 1px solid var(--border);
        padding-top: 0.8rem;
        margin-top: 0.6rem;
        position: relative;
      }
      .ep-expand.show {
        display: block;
      }
      .ep-syn {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.92rem;
        color: var(--text-2);
        line-height: 1.7;
        text-wrap: pretty;
      }

      /* ── SIZE CHART ── */
      .size-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 2rem;
        overflow-x: auto;
        overflow-y: visible;
        overflow: visible;
      }
      .size-bars {
        display: flex;
        align-items: flex-end;
        gap: 4px;
        height: 300px;
        border-bottom: 1px solid var(--border-2);
        min-width: 600px;
        padding-bottom: 0;
        margin-bottom: 3rem;
      }
      .sbar-col {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        height: 100%;
        justify-content: flex-end;
        position: relative;
        cursor: pointer;
      }
      .sbar-val {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--nuclear);
        margin-bottom: 0.4rem;
        text-align: center;
      }
      .sbar {
        width: 100%;
        transition: height 1.2s cubic-bezier(0.34, 1.56, 0.64, 1);
        min-width: 28px;
      }
      .sbar-inner {
        width: 100%;
        height: 100%;
        background: linear-gradient(to top, var(--nuclear-2), var(--nuclear));
        opacity: 0.75;
        position: relative;
      }
      .sbar-inner::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: #fff;
        box-shadow: 0 0 8px var(--nuclear);
      }
      .sbar:hover .sbar-inner {
        opacity: 1;
      }
      .sbar-label {
        font-size: 1.2rem;
        margin-top: 0.8rem;
        text-align: center;
        display: block;
        line-height: 1;
        padding-bottom: 0.3rem;
      }
      .sbar-col .sbar-tooltip {
        display: none;
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%) translateY(-110%);
        background: var(--surface-2);
        border: 1px solid var(--nuclear);
        color: var(--nuclear);
        font-family: var(--font-mono);
        font-size: 0.62rem;
        letter-spacing: 1px;
        padding: 0.3rem 0.6rem;
        white-space: nowrap;
        z-index: 10;
        pointer-events: none;
      }
      .sbar-col:hover .sbar-tooltip {
        display: block;
      }
      .size-legend {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.5rem;
        margin-top: 1.5rem;
      }
      .sleg {
        display: flex;
        align-items: flex-start;
        gap: 0.7rem;
        padding: 0.35rem;
      }
      .sleg-bar {
        width: 10px;
        height: 10px;
        background: var(--nuclear);
        flex-shrink: 0;
        margin-top: 3px;
      }
      .sleg-info {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--text-2);
      }
      .sleg-info span {
        color: var(--nuclear);
      }

      /* ── RELATION WEB ── */
      #relcanvas {
        width: 100%;
        height: 520px;
        background: var(--surface);
        border: 1px solid var(--border);
        cursor: grab;
        display: block;
      }
      #relcanvas:active {
        cursor: grabbing;
      }
      .rel-leg {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
      }
      .rleg {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--muted);
        letter-spacing: 1px;
      }
      .rleg-line {
        width: 28px;
        height: 2px;
      }

      /* ── BATTLE SIM ── */
      /* Arena Row */
      .arena-row {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
      }
      .arena-card {
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 0.65rem 1rem;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex: 1;
        min-width: 120px;
      }
      .arena-card:hover {
        border-color: var(--border-2);
        background: var(--surface-2);
      }
      .arena-card.on {
        background: rgba(0, 255, 136, 0.06);
        border-color: var(--nuclear);
      }
      .arena-card:active {
        transform: scale(0.98);
        transition: transform 0.1s;
      }
      .arena-e {
        font-size: 1.3rem;
        line-height: 1;
      }
      .arena-info {
        display: flex;
        flex-direction: column;
      }
      .arena-n {
        font-family: var(--font-ui);
        font-size: 0.85rem;
        font-weight: 700;
        color: #fff;
        letter-spacing: 1px;
      }
      .arena-t {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--muted);
        letter-spacing: 1px;
        margin-top: 1px;
      }

      /* Sim layout */
      .sim-layout {
        display: grid;
        grid-template-columns: 1fr 170px 1fr;
        gap: 1.5rem;
        align-items: start;
      }
      @media (max-width: 700px) {
        .sim-layout {
          grid-template-columns: 1fr;
        }
      }
      .sim-slot {
        background: var(--surface);
        border: 2px solid var(--border);
        padding: 1.5rem 1.2rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.25s;
        min-height: 300px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0rem;
        position: relative;
        overflow: hidden;
      }
      .sim-slot::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        transition: all 0.25s;
      }
      .sim-slot.sel::before {
        background: linear-gradient(
          90deg,
          transparent,
          var(--nuclear),
          transparent
        );
      }
      .sim-slot.sel2::before {
        background: linear-gradient(
          90deg,
          transparent,
          var(--hostile),
          transparent
        );
      }
      .sim-slot:hover {
        background: var(--surface-2);
      }
      .sim-slot:active {
        transform: scale(0.98);
        transition: transform 0.1s;
      }
      .sim-slot.sel {
        border-color: var(--nuclear);
        background: rgba(0, 255, 136, 0.04);
        box-shadow:
          0 0 0 1px rgba(0, 255, 136, 0.1),
          inset 0 0 30px rgba(0, 255, 136, 0.03);
      }
      .sim-slot.sel2 {
        border-color: var(--hostile) !important;
        background: rgba(255, 77, 0, 0.04);
        box-shadow:
          0 0 0 1px rgba(255, 77, 0, 0.1),
          inset 0 0 30px rgba(255, 77, 0, 0.03);
      }
      .sim-ph {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 3px;
      }
      .sim-slot-ph-icon {
        font-size: 2.5rem;
        opacity: 0.2;
        margin-bottom: 0.3rem;
      }
      .sim-emoji {
        font-size: 4.5rem;
        filter: drop-shadow(0 6px 20px rgba(0, 0, 0, 0.6));
        animation: floatfeat 4s ease-in-out infinite;
        margin-bottom: 0.6rem;
      }
      .sim-name {
        font-family: var(--font-display);
        font-size: 1.6rem;
        color: #fff;
        letter-spacing: 3px;
      }
      .sim-alias {
        font-family: var(--font-mono);
        font-size: 0.88rem;
        color: var(--muted);
        letter-spacing: 2px;
        margin-top: 0.45rem;
      }
      .sim-slot-badge {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 0.7rem;
      }
      .sim-slot-badge .badge {
        font-size: 0.78rem !important;
        padding: 0.25rem 0.75rem !important;
        letter-spacing: 1.5px;
      }
      .sim-powers {
        margin-top: 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        justify-content: center;
        width: 100%;
      }
      .sim-power-tag {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        background: rgba(0, 255, 136, 0.07);
        border: 1px solid rgba(0, 255, 136, 0.22);
        color: var(--nuclear);
        padding: 0.38rem 0.8rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition:
          background 0.15s,
          border-color 0.15s;
        cursor: default;
      }
      .sim-power-tag:hover {
        background: rgba(0, 255, 136, 0.14);
        border-color: rgba(0, 255, 136, 0.4);
      }
      .sim-power-tag .pow-icon {
        font-size: 1.1rem;
        line-height: 1;
        flex-shrink: 0;
      }
      .sim-power-tag.r2 {
        background: rgba(255, 77, 0, 0.07);
        border-color: rgba(255, 77, 0, 0.22);
        color: var(--hostile);
      }
      .sim-power-tag.r2:hover {
        background: rgba(255, 77, 0, 0.14);
        border-color: rgba(255, 77, 0, 0.4);
      }
      .sim-power-more {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--muted);
        border: 1px dashed var(--border-2);
        padding: 0.38rem 0.8rem;
        display: inline-flex;
        align-items: center;
        cursor: default;
      }
      .sim-change {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--muted);
        letter-spacing: 2px;
        margin-top: 1rem;
        opacity: 0;
        transition: opacity 0.2s;
      }
      .sim-slot:hover .sim-change {
        opacity: 1;
      }

      /* VS middle */
      .sim-mid {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        padding-top: 3rem;
      }
      .vs-txt {
        font-family: var(--font-display);
        font-size: 3.5rem;
        color: var(--hostile);
        text-shadow: 0 0 25px rgba(255, 77, 0, 0.5);
        animation: vspulse 2s ease-in-out infinite;
      }
      @keyframes vspulse {
        0%,
        100% {
          text-shadow: 0 0 20px rgba(255, 77, 0, 0.4);
        }
        50% {
          text-shadow:
            0 0 40px rgba(255, 77, 0, 0.8),
            0 0 60px rgba(255, 77, 0, 0.3);
        }
      }
      .fight-btn {
        background: linear-gradient(135deg, var(--hostile), #cc4400);
        color: #fff;
        border: none;
        padding: 0.9rem 1.6rem;
        font-family: var(--font-display);
        font-size: 1.1rem;
        letter-spacing: 4px;
        cursor: pointer;
        clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
        transition: all 0.2s;
        width: 100%;
        box-shadow: 0 4px 20px rgba(255, 77, 0, 0.3);
      }
      .fight-btn:hover:not(:disabled) {
        background: linear-gradient(135deg, #ff7744, var(--hostile));
        transform: scale(1.04);
        box-shadow: 0 6px 28px rgba(255, 77, 0, 0.5);
      }
      .fight-btn:active:not(:disabled) {
        transform: scale(0.97);
        transition: transform 0.08s;
      }
      .fight-btn:disabled {
        opacity: 0.35;
        cursor: not-allowed;
        box-shadow: none;
      }
      .fight-btn.running {
        animation: fightpulse 0.6s ease-in-out infinite;
      }
      @keyframes fightpulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.6;
        }
      }
      .arena-indicator {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--muted);
        letter-spacing: 2px;
        text-align: center;
        margin-top: 0.3rem;
      }

      /* Picker */
      .sim-picker {
        background: var(--surface);
        border: 1px solid var(--border);
        border-top: 2px solid var(--nuclear);
        padding: 1.2rem;
        margin-bottom: 1.2rem;
        display: none;
      }
      .sim-picker.show {
        display: block;
        animation: fadeup 0.2s ease;
      }
      .sim-picker.pick2 {
        border-top-color: var(--hostile);
      }
      .pick-lbl {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 3px;
        margin-bottom: 0.7rem;
      }
      .pick-lbl.p1 {
        color: var(--nuclear);
      }
      .pick-lbl.p2 {
        color: var(--hostile);
      }
      .pick-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 0.5rem;
        max-height: 300px;
        overflow-y: auto;
        margin-top: 0.7rem;
      }
      .pick-card {
        background: var(--surface-2);
        border: 1px solid var(--border);
        padding: 0.85rem 0.6rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.15s;
        position: relative;
      }
      .pick-card:hover {
        border-color: var(--nuclear);
        background: var(--surface-3);
        transform: translateY(-1px);
      }
      .pick-card:active {
        transform: scale(0.97);
        transition: transform 0.08s;
      }
      .pick-e {
        font-size: 2.2rem;
      }
      .pick-n {
        font-family: var(--font-ui);
        font-size: 0.88rem;
        font-weight: 700;
        color: #fff;
        margin-top: 0.35rem;
        line-height: 1.2;
      }
      .pick-t {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        color: var(--muted);
        letter-spacing: 1px;
        margin-top: 0.2rem;
      }

      /* Combat log */
      .combat-log-wrap {
        margin-top: 1.5rem;
        background: var(--void);
        border: 1px solid var(--border);
        padding: 1.2rem;
        display: none;
        min-height: 180px;
      }
      .combat-log-wrap.show {
        display: block;
        animation: fadeup 0.3s ease;
      }
      .clog-head {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--nuclear);
        letter-spacing: 3px;
        margin-bottom: 0.8rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .clog-head::before {
        content: "";
        width: 6px;
        height: 6px;
        background: var(--nuclear);
        border-radius: 50%;
        animation: blinktag 1.2s infinite;
      }
      .clog-body {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        font-family: var(--font-mono);
        font-size: 0.78rem;
      }
      .clog-line {
        color: var(--text-2);
        letter-spacing: 0.5px;
        line-height: 1.5;
        opacity: 0;
        transform: translateY(4px);
        transition: all 0.3s;
      }
      .clog-line.in {
        opacity: 1;
        transform: translateY(0);
      }
      .clog-line.hit {
        color: #fff;
      }
      .clog-line.crit {
        color: var(--hostile);
      }
      .clog-line.block {
        color: var(--sky);
      }
      .clog-line.win {
        color: var(--nuclear);
        font-weight: 700;
        letter-spacing: 2px;
      }
      .clog-cursor {
        display: inline-block;
        width: 8px;
        height: 1em;
        background: var(--nuclear);
        vertical-align: middle;
        animation: blinktag 0.8s infinite;
        margin-left: 2px;
      }

      /* Results */
      .sim-result {
        margin-top: 1.5rem;
        display: none;
      }
      .sim-result.show {
        display: block;
        animation: fadeup 0.3s ease-out;
      }
      .res-inner {
        background: var(--surface-2);
        border: 1px solid var(--border-2);
        border-top: 2px solid var(--nuclear);
        padding: 2rem;
      }
      .res-h {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--nuclear);
        letter-spacing: 4px;
        margin-bottom: 1.5rem;
        text-align: center;
      }
      .res-winner {
        text-align: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
      }
      .res-we {
        font-size: 4rem;
        display: block;
        filter: drop-shadow(0 0 20px rgba(0, 255, 136, 0.3));
        animation: floatfeat 3s ease-in-out infinite;
      }
      .res-wn {
        font-family: var(--font-display);
        font-size: 2.5rem;
        color: #fff;
        letter-spacing: 4px;
        margin-top: 0.5rem;
      }
      .res-wl {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--nuclear);
        letter-spacing: 3px;
        margin-top: 0.3rem;
      }
      .res-cols {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 4rem;
        margin-top: 3rem;
        align-items: center;
      }
      @media (max-width: 800px) {
        .res-cols {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }
      .res-analysis {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 1.05rem;
        color: var(--text-2);
        line-height: 1.8;
        border-left: 3px solid var(--nuclear);
        background: rgba(0, 255, 136, 0.03);
        margin-top: 2rem;
        padding: 1.4rem 1.8rem;
      }

      /* Probability bar */
      .prob-section {
        margin-top: 3rem;
      }
      .prob-label {
        display: flex;
        justify-content: space-between;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--text);
        letter-spacing: 3px;
        margin-bottom: 1rem;
      }
      .prob-bar {
        height: 6px;
        background: var(--surface-2);
        border-radius: 3px;
        display: flex;
        overflow: hidden;
        box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.5);
      }
      .prob-fill-a {
        height: 100%;
        background: linear-gradient(90deg, var(--nuclear), var(--nuclear-2));
        transition: width 1s cubic-bezier(0.34, 1.56, 0.64, 1);
        box-shadow: 0 0 10px var(--nuclear-glow);
      }
      .prob-fill-b {
        height: 100%;
        background: linear-gradient(90deg, #cc4400, var(--hostile));
        transition: width 1s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      .prob-pct {
        display: flex;
        justify-content: space-between;
        font-family: var(--font-display);
        font-size: 1.5rem;
        margin-top: 0.6rem;
        font-variant-numeric: tabular-nums;
      }
      .prob-pct .pa {
        color: var(--nuclear);
      }
      .prob-pct .pb {
        color: var(--hostile);
      }

      /* Stat comparison table */
      .stat-cmp {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }
      .sc-row {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 1rem;
        align-items: center;
      }
      .sc-v {
        padding: 0;
        font-family: var(--font-mono);
        font-size: 1.1rem;
        font-weight: 700;
        font-variant-numeric: tabular-nums;
      }
      .sc-v.l {
        text-align: right;
      }
      .sc-v.r {
        text-align: left;
      }
      .sc-lbl {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--text-2);
        text-align: center;
        padding: 0.4rem 0.8rem;
        letter-spacing: 3px;
        white-space: nowrap;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 20px;
        border: 1px solid var(--border);
      }
      .sc-win {
        color: var(--nuclear);
      }
      .sc-lose {
        color: var(--border-3);
      }

      /* Radar canvas */
      #radar-canvas {
        display: block;
        margin: 0 auto;
      }

      /* Battle history */
      .battle-hist {
        margin-top: 1.5rem;
      }
      .hist-head {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--muted);
        letter-spacing: 3px;
        margin-bottom: 0.6rem;
      }
      .hist-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .hist-item {
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 0.5rem 1rem;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--text-2);
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .hist-item:hover {
        border-color: var(--nuclear);
        color: var(--nuclear);
      }
      .hist-item:active {
        transform: scale(0.98);
        transition: transform 0.1s;
      }
      .hist-win {
        color: var(--nuclear);
        font-weight: 700;
      }
      .hist-vs {
        color: var(--muted);
        font-size: 0.62rem;
      }

      /* ── MONARCH TIMELINE ── */
      .tl-wrap {
        position: relative;
        padding-left: 2rem;
      }
      .tl-wrap::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 1px;
        background: linear-gradient(
          to bottom,
          transparent,
          var(--border-2) 5%,
          var(--border-2) 95%,
          transparent
        );
      }
      .tlev {
        position: relative;
        padding: 0 0 2.5rem 2rem;
      }
      .tlev::before {
        content: "";
        position: absolute;
        left: -4px;
        top: 8px;
        width: 9px;
        height: 9px;
        background: var(--nuclear);
        border: 2px solid var(--deep);
        border-radius: 50%;
        box-shadow: 0 0 8px var(--nuclear);
      }
      .tlev-yr {
        font-family: var(--font-display);
        font-size: 1.05rem;
        color: var(--nuclear);
        letter-spacing: 3px;
        margin-bottom: 0.4rem;
      }
      .tlev-card {
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 1rem 1.2rem;
        border-left: 3px solid;
      }
      .tlev-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.3rem;
      }
      .tlev-desc {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 0.88rem;
        color: var(--text-2);
        line-height: 1.65;
      }
      .tlev-tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        margin-top: 0.6rem;
      }
      .ttag {
        font-family: var(--font-mono);
        font-size: 0.52rem;
        padding: 0.12rem 0.5rem;
        border: 1px solid;
      }

      /* ── FOOTER ── */
      .site-footer {
        background: var(--void);
        border-top: 1px solid var(--border);
        padding: 3.5rem 2rem 2rem;
      }
      .footer-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 3rem;
      }
      @media (max-width: 700px) {
        .footer-inner {
          grid-template-columns: 1fr;
        }
      }
      .fb-name {
        font-family: var(--font-display);
        font-size: 1.5rem;
        letter-spacing: 4px;
      }
      .fb-name .mo {
        color: var(--nuclear);
      }
      .fb-name .in {
        color: #fff;
      }
      .fb-sub {
        font-family: var(--font-mono);
        font-size: 0.48rem;
        color: var(--muted);
        letter-spacing: 3px;
        margin-top: 0.2rem;
      }
      .fb-desc {
        font-size: 0.88rem;
        color: var(--muted);
        line-height: 1.65;
        margin-top: 1rem;
      }
      .fc-head {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--nuclear);
        letter-spacing: 3px;
        margin-bottom: 1rem;
      }
      .fc-link {
        display: block;
        font-size: 0.9rem;
        color: var(--text-2);
        margin-bottom: 0.45rem;
        text-decoration: none;
        cursor: pointer;
        transition: color 0.2s;
      }
      .fc-link:hover {
        color: var(--nuclear);
      }
      .footer-bottom {
        max-width: 1400px;
        margin: 2rem auto 0;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .footer-copy {
        font-family: var(--font-mono);
        font-size: 0.58rem;
        color: var(--muted);
        letter-spacing: 2px;
      }
      .footer-disc {
        font-family: var(--font-mono);
        font-size: 0.52rem;
        color: var(--border-2);
        letter-spacing: 1px;
        max-width: 500px;
        text-align: right;
        line-height: 1.6;
      }

      /* ── ATTRIBUTION UI ── */
      .attr-wrap {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .attr-icon {
        position: relative;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 1px solid var(--border-2);
        color: var(--muted);
        font-family: var(--font-serif);
        font-size: 0.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: help;
        transition: all 0.2s;
        background: var(--surface);
      }
      .attr-icon::before {
        content: "";
        position: absolute;
        inset: -7px;
        border-radius: 50%;
      }
      .attr-wrap:hover .attr-icon {
        border-color: var(--nuclear);
        color: var(--nuclear);
        background: rgba(0, 255, 136, 0.05);
      }
      .attr-pop {
        position: absolute;
        bottom: calc(100% + 8px);
        right: 0;
        width: 280px;
        background: rgba(4, 10, 14, 0.98);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border-2);
        padding: 1rem;
        opacity: 0;
        visibility: hidden;
        transform: translateY(4px);
        transition: all 0.2s;
        z-index: 9999;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        text-align: left;
      }
      /* Ensure the popover doesn't get clipped by parents if they have overflow hidden */
      .attr-wrap:hover .attr-pop {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
      .attr-pop::after {
        content: "";
        position: absolute;
        top: 100%;
        right: 8px;
        border-width: 6px;
        border-style: solid;
        border-color: var(--border-2) transparent transparent transparent;
      }
      /* Down-direction variant — tooltip opens below the icon */
      .attr-wrap.down .attr-pop {
        bottom: auto;
        top: calc(100% + 8px);
        transform: translateY(-4px);
      }
      .attr-wrap.down:hover .attr-pop {
        transform: translateY(0);
      }
      .attr-wrap.down .attr-pop::after {
        top: auto;
        bottom: 100%;
        border-color: transparent transparent var(--border-2) transparent;
      }
      .ap-sec {
        margin-bottom: 0.8rem;
      }
      .ap-sec:last-child {
        margin-bottom: 0;
