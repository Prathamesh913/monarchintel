      </div>
    `,
              )
              .join("") +
            `</div>`;
        }

        const dirClass = dir === "down" ? " down" : "";
        return `
    <div class="attr-wrap${dirClass}" title="View attributions">
      <div class="attr-icon">i</div>
      <div class="attr-pop">${popHTML}</div>
