let activeShow='monarch';
function renderShowTabs(){
  document.getElementById('show-tabs').innerHTML=SHOWS.map(s=>`
    <button class="stab ${s.id===activeShow?'on':''}" onclick="switchShow('${s.id}')">${s.emoji} ${s.title.split(':')[0]||s.title.split(' ').slice(0,2).join(' ')}</button>
  `).join('');
}
function switchShow(id){activeShow=id;renderShowTabs();renderEps();}
function renderEps(){
  const show=SHOWS.find(s=>s.id===activeShow);
  document.getElementById('ep-list').innerHTML=show.episodes.map(ep=>`
    <div class="ep-item" onclick="toggleEp(this)">
      <div class="ep-num">${String(ep.num).padStart(2,'0')}</div>
      <div>
        <div class="ep-title">${ep.title}</div>
        <div class="ep-air">${ep.air}</div>
        <div class="ep-titans">${ep.titans.map(t=>`<span class="ep-tag">${t}</span>`).join('')}</div>
        <div class="ep-expand">
          <div class="ep-syn">${ep.synopsis}</div>
        </div>
      </div>
    </div>
  `).join('');
}
function toggleEp(el){const ex=el.querySelector('.ep-expand');ex.classList.toggle('show');el.classList.toggle('open')}
