function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.mnav').forEach(b=>b.classList.remove('on'));
  document.getElementById('page-'+id).classList.add('on');
  document.querySelectorAll('.mnav').forEach(b=>{if(b.textContent.toLowerCase().replace(' ','').includes(id.replace('watchorder','watch').replace('titandex','titandex').replace('sizechart','size').replace('battle','battle').replace('timeline','timeline').replace('episodes','ep').replace('relations','rel').replace('dossier','dossier').replace('home','home')))b.classList.add('on')});
  window.scrollTo(0,0);
  if(id==='relations') initCanvas();
  if(id==='sizechart') renderSize(SIZES);
}

// ═══════════════════════════════════════════════════
//  WATCH ORDER
// ═══════════════════════════════════════════════════
let woEra = 'all';
function renderWO(data){
  const el = document.getElementById('wo-list');
  document.getElementById('wo-count').textContent = data.length+' ENTRIES';
  el.innerHTML = data.map((m,i)=>`
    <div class="wo-item" onclick="toggleWO(this)" data-era="${m.era}">
      <div class="wo-num">${String(m.num).padStart(2,'0')}</div>
      <div class="wo-icon">${m.icon}</div>
      <div class="wo-body">
        <div class="wo-title">${m.title}</div>
        <div class="wo-meta">
          <span class="wo-year">${m.year}</span>
          <span class="epill e-${m.era}">${m.era.toUpperCase()}</span>
          <span class="wo-year">${m.type==='film'?'Film':'Series'} · ${m.duration}</span>
        </div>
        <div class="wo-chips">${m.titans.slice(0,4).map(t=>`<span class="wo-chip">${t}</span>`).join('')}${m.titans.length>4?`<span class="wo-chip">+${m.titans.length-4}</span>`:''}</div>
        <div class="wo-expand">
          <div class="wo-exp-grid">
            <div class="wo-ef"><label>Platform</label><span>${m.platform}</span></div>
            <div class="wo-ef"><label>Director</label><span>${m.director}</span></div>
            <div class="wo-ef"><label>Duration</label><span>${m.duration}</span></div>
          </div>
          <div class="wo-syn">${m.synopsis}</div>
          ${m.highlights?`<div style="font-family:var(--font-mono);font-size:0.72rem;color:var(--nuclear);letter-spacing:2px;margin-top:0.8rem;line-height:1.6">★ ${m.highlights}</div>`:''}
        </div>
      </div>
      <div class="wo-right"><div class="wo-score">★${m.score}</div><div class="wo-plat">${m.platform}</div></div>
    </div>
  `).join('');
}
function toggleWO(el){const ex=el.querySelector('.wo-expand');ex.classList.toggle('show');el.classList.toggle('open')}
function filterWO(){
  const q=document.getElementById('wo-search').value.toLowerCase();
  const f=MOVIES.filter(m=>(woEra==='all'||m.era===woEra)&&(m.title.toLowerCase().includes(q)||m.titans.join(' ').toLowerCase().includes(q)));
  renderWO(f);
}
function filterWOEra(btn,era){document.querySelectorAll('#page-watchorder .tog').forEach(b=>b.classList.remove('on'));btn.classList.add('on');woEra=era;filterWO();}
renderWO(MOVIES);

// ═══════════════════════════════════════════════════
//  TITANDEX
// ═══════════════════════════════════════════════════
function renderTdex(data){
  document.getElementById('tdex-count').textContent=data.length+' TITANS';
  document.getElementById('tdex-grid').innerHTML=data.map(t=>`
    <div class="tcard" data-a="${t.align}" onclick="openTitan('${t.id}')">
      <div class="tc-top"><span class="tc-id">${t.id}</span><span class="badge b-sm tl-${t.threat.toLowerCase()}">${t.threat.toUpperCase()}</span></div>
      <div class="tc-emoji">${t.emoji}</div>
      <div class="tc-name">${t.name}</div>
      <div class="tc-alias">${t.alias}</div>
      <div class="tc-div"></div>
      <div class="tc-stats">
        <div class="tcs"><label>Alignment</label><span class="al-${t.align}">${t.align.toUpperCase()}</span></div>
        <div class="tcs"><label>Status</label><span class="st-${t.status}">${t.status.toUpperCase()}</span></div>
        <div class="tcs"><label>Height</label><span>${t.height}</span></div>
        <div class="tcs"><label>First Seen</label><span>${t.first}</span></div>
      </div>
      <div class="tc-pbar">${Array.from({length:10},(_,i)=>`<div class="tcpb ${i<Math.round(50/10)?'on':''}"></div>`).join('')}</div>
      <div class="tc-hint">CLICK FOR FULL DOSSIER</div>
    </div>
  `).join('');
}
function filterTdex(){
  const q=document.getElementById('tdex-search').value.toLowerCase();
  const a=document.getElementById('tdex-align').value.toLowerCase();
  const th=document.getElementById('tdex-threat').value.toLowerCase();
  const st=document.getElementById('tdex-status').value.toLowerCase();
  renderTdex(TITANS.filter(t=>
    (t.name.toLowerCase().includes(q)||t.alias.toLowerCase().includes(q))&&
    (!a||t.align===a)&&(!th||t.threat.toLowerCase()===th)&&(!st||t.status===st)
  ));
}
renderTdex(TITANS);

function openTitan(id){
