        document.getElementById("sources-data").textContent,
      );

      function getAttrHTML(sourcesObj, dir) {
        if (!sourcesObj) return "";
        const dSrcs = (sourcesObj.data || [])
          .map((k) => SOURCES[k])
          .filter(Boolean);
        const iSrcs = (sourcesObj.image || [])
          .map((k) => SOURCES[k])
          .filter(Boolean);
        if (!dSrcs.length && !iSrcs.length) return "";

        let popHTML = "";
        if (dSrcs.length) {
          popHTML +=
            `<div class="ap-sec"><div class="ap-lbl">DATA SOURCES</div>` +
            dSrcs
              .map(
                (s) => `
      <div class="ap-item">
        ${s.logo ? `<img class="ap-logo" src="${s.logo}" alt="${s.name}">` : `<div class="ap-logo" style="background:var(--border)"></div>`}
        <div class="ap-txt"><strong>${s.url ? `<a href="${s.url}" target="_blank" rel="noopener">${s.name}</a>` : s.name}</strong>${s.credit}</div>
      </div>
    `,
              )
              .join("") +
            `</div>`;
        }
        if (iSrcs.length) {
          popHTML +=
            `<div class="ap-sec"><div class="ap-lbl">IMAGE SOURCES</div>` +
            iSrcs
              .map(
                (s) => `
      <div class="ap-item">
