  if(!t)return;
  const accentColor={alpha:'var(--alpha)',hostile:'var(--hostile)',benevolent:'var(--benevolent)',neutral:'var(--neutral)',unknown:'var(--sky)'}[t.align]||'var(--nuclear)';
  document.getElementById('modal-content').innerHTML=`
    <div class="mhd" style="border-top:3px solid ${accentColor}">
      <div class="mhd-info">
        <div class="mid-lbl">${t.id} — MONARCH CLASSIFIED DOSSIER</div>
        <div class="mhd-name">${t.name.toUpperCase()}</div>
        <div class="mhd-alias">${t.alias}</div>
      </div>
      <button class="mclose" onclick="closeModal()">✕</button>
    </div>
    <div class="mbody">
      <div>
        <div class="mdisp">
          <div class="memoji">${t.emoji}</div>
          <span class="badge b-sm tl-${t.threat.toLowerCase()}" style="margin-top:0.5rem">${t.threat.toUpperCase()} THREAT</span>
          <span class="badge b-sm" style="border-color:${accentColor};color:${accentColor};margin-top:0.3rem">${t.align.toUpperCase()}</span>
          <span class="badge b-sm st-${t.status}" style="border-color:var(--${t.status});color:var(--${t.status});margin-top:0.3rem">${t.status.toUpperCase()}</span>
        </div>
        <div style="margin-top:0.7rem">
          <div class="tc-pbar">${Array.from({length:10},(_,i)=>`<div class="tcpb ${i<Math.round(50/10)?'on':''}"></div>`).join('')}</div>
          <div style="font-family:var(--font-mono);font-size:0.56rem;color:var(--muted);letter-spacing:2px;margin-top:0.4rem;text-align:center">POWER INDEX: ${50}/100</div>
        </div>
      </div>
      <div class="mright">
        <div class="mstats">
          <div class="msr"><label>Height</label><span class="v">${t.height}</span></div>
          <div class="msr"><label>Weight</label><span class="v">${t.weight}</span></div>
          <div class="msr"><label>Habitat</label><span class="v" style="font-size:0.78rem">${t.habitat}</span></div>
          <div class="msr"><label>First Documented</label><span class="v">${t.first}</span></div>
          <div class="msr"><label>Era</label><span class="v">${t.era}</span></div>
        </div>
        <div class="mblock">
          <div class="mblock-t">MONARCH FIELD REPORT</div>
          <div style="font-family:var(--font-serif);font-style:italic;font-size:0.9rem;color:var(--text-2);line-height:1.7">${t.origin}</div>
        </div>
      </div>
      <div class="mblock" style="grid-column:1/-1">
        <div class="mblock-t">DOCUMENTED ABILITIES</div>
        <div class="mtags">${t.powers.map(p=>`<span class="ptag">${p}</span>`).join('')}</div>
      </div>
      <div class="mblock" style="grid-column:1/-1">
        <div class="mblock-t">KNOWN WEAKNESSES</div>
        <div class="mtags">${[t.weakness].map(w=>`<span class="atag">${w}</span>`).join('')}</div>
      </div>
      <div class="mblock" style="grid-column:1/-1">
        <div class="mblock-t">DOCUMENTED APPEARANCES</div>
        <div class="mtags">${[t.first].map(a=>`<span class="ptag">${a}</span>`).join('')}</div>
      </div>
    </div>
  `;
  document.getElementById('titan-modal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){document.getElementById('titan-modal').classList.remove('open');document.body.style.overflow='';}

