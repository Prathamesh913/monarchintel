  `).join('');
}

// ═══════════════════════════════════════════════════
//  RELATIONSHIP CANVAS
// ═══════════════════════════════════════════════════
let canvasInitialized=false,animFrame,dragging=null,dragOffset={x:0,y:0};
const nodeState=[...NODES.map(n=>({...n,vx:0,vy:0}))];
function initCanvas(){
  if(canvasInitialized)return;
  canvasInitialized=true;
  const canvas=document.getElementById('relcanvas');
  const ctx=canvas.getContext('2d');
  canvas.width=canvas.offsetWidth;canvas.height=canvas.offsetHeight;
  const edgeColor={ally:'#00ff88',enemy:'#ff0055',alpha:'#e8b400',neutral:'#2a5070'};
  function draw(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    EDGES.forEach(e=>{
      const a=nodeState.find(n=>n.id===e.a),b=nodeState.find(n=>n.id===e.b);
      if(!a||!b)return;
      ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);
      ctx.strokeStyle=edgeColor[e.type]||'#2a5070';ctx.lineWidth=e.type==='enemy'?2:1.5;
      if(e.type==='enemy'){ctx.setLineDash([5,5])}else{ctx.setLineDash([])}
      ctx.globalAlpha=0.5;ctx.stroke();ctx.globalAlpha=1;ctx.setLineDash([]);
      const mx=(a.x+b.x)/2,my=(a.y+b.y)/2;
      ctx.font='10px Share Tech Mono';ctx.fillStyle=edgeColor[e.type];ctx.textAlign='center';
      ctx.fillText(e.label,mx,my-4);
    });
    nodeState.forEach(n=>{
      ctx.beginPath();ctx.arc(n.x,n.y,28,0,Math.PI*2);
      ctx.fillStyle=n.color+'22';ctx.fill();
      ctx.strokeStyle=n.color;ctx.lineWidth=1.5;ctx.stroke();
      ctx.font='22px serif';ctx.textAlign='center';ctx.textBaseline='middle';
      ctx.fillText(n.emoji,n.x,n.y-2);
      ctx.font='bold 9px Share Tech Mono';ctx.fillStyle=n.color;ctx.textBaseline='top';
      ctx.fillText(n.label,n.x,n.y+22);
    });
    animFrame=requestAnimationFrame(draw);
  }
  draw();
  function getNode(e){const r=canvas.getBoundingClientRect();const cx=e.clientX-r.left,cy=e.clientY-r.top;return nodeState.find(n=>Math.hypot(n.x-cx,n.y-cy)<32)}
  canvas.addEventListener('mousedown',e=>{const n=getNode(e);if(n){dragging=n;const r=canvas.getBoundingClientRect();dragOffset={x:n.x-(e.clientX-r.left),y:n.y-(e.clientY-r.top)}}});
  canvas.addEventListener('mousemove',e=>{if(!dragging)return;const r=canvas.getBoundingClientRect();dragging.x=e.clientX-r.left+dragOffset.x;dragging.y=e.clientY-r.top+dragOffset.y});
  canvas.addEventListener('mouseup',()=>{dragging=null});
  canvas.addEventListener('touchstart',e=>{const t=e.touches[0];const r=canvas.getBoundingClientRect();const n=nodeState.find(n=>Math.hypot(n.x-(t.clientX-r.left),n.y-(t.clientY-r.top))<36);if(n){dragging=n;dragOffset={x:n.x-(t.clientX-r.left),y:n.y-(t.clientY-r.top)}}},{passive:true});
  canvas.addEventListener('touchmove',e=>{if(!dragging)return;const t=e.touches[0];const r=canvas.getBoundingClientRect();dragging.x=t.clientX-r.left+dragOffset.x;dragging.y=t.clientY-r.top+dragOffset.y;e.preventDefault();},{passive:false});
  canvas.addEventListener('touchend',()=>{dragging=null});
}

// ═══════════════════════════════════════════════════
//  BATTLE SIMULATOR
// ═══════════════════════════════════════════════════
let picks=[null,null],pickingSlot=null;
function renderPickGrid(query=''){
  const f=TITANS.filter(t=>t.name.toLowerCase().includes(query.toLowerCase())||t.alias.toLowerCase().includes(query.toLowerCase()));
  document.getElementById('pick-grid').innerHTML=f.map(t=>`
    <div class="pick-card" onclick="selectTitan(${TITANS.indexOf(t)})">
      <div class="pick-e">${t.emoji}</div>
      <div class="pick-n">${t.name}</div>
    </div>
  `).join('');
}
function openPicker(slot){
  pickingSlot=slot;
  document.getElementById('picker-label').textContent=`SELECT TITAN ${slot}`;
  document.getElementById('sim-picker').classList.add('show');
  document.getElementById('pick-search').value='';
  renderPickGrid();
}
function filterPicker(){renderPickGrid(document.getElementById('pick-search').value)}
function selectTitan(idx){
  const t=TITANS[idx];picks[pickingSlot-1]=t;
  const slot=document.getElementById(`slot${pickingSlot}`);
  document.getElementById(`slot${pickingSlot}-ph`).style.display='none';
  document.getElementById(`slot${pickingSlot}-e`).textContent=t.emoji;document.getElementById(`slot${pickingSlot}-e`).style.display='block';
  document.getElementById(`slot${pickingSlot}-n`).textContent=t.name;document.getElementById(`slot${pickingSlot}-n`).style.display='block';
  if(pickingSlot===1)slot.classList.add('sel');else{slot.classList.add('sel2');slot.style.borderColor='var(--hostile)';}
  document.getElementById('sim-picker').classList.remove('show');
  if(picks[0]&&picks[1])document.getElementById('fight-btn').disabled=false;
}
function runBattle(){
  const [a,b]=picks;
    const threatScore = {omega:4, high:3, medium:2, low:1};
  const scoreA = (threatScore[a.threat]||1)*25 + (parseFloat(a.height)*0.1);
  const scoreB = (threatScore[b.threat]||1)*25 + (parseFloat(b.height)*0.1);
  const winner=scoreA>=scoreB?a:b,loser=scoreA>=scoreB?b:a;
  const margin=Math.abs(scoreA-scoreB);
  const closeness=margin<10?'an extremely close battle — the outcome could go either way in the field':'a decisive engagement';
  const analysis=`Monarch Combat Assessment: Based on biometric data, documented power output, and field engagement records, ${winner.name} holds a tactical advantage over ${loser.name}. ${winner.name}'s ${winner.powers[0].toLowerCase()} capability combined with its ${winner.threat.toLowerCase()}-tier classification gives it the edge in ${closeness}. ${loser.name}'s ${loser.powers[0].toLowerCase()} would be the primary counter-threat. Estimated engagement duration: ${margin<10?'48+ hours':'6–12 hours'}. Monarch recommendation: avoid engagement zone.`;
  const cmp=[
    {label:'THREAT TIER', va:threatScore[a.threat]||1, vb:threatScore[b.threat]||1, labels:['Low','Medium','High','Omega']},
    {label:'HEIGHT',va:parseFloat(a.height),vb:parseFloat(b.height)},
  ];
  document.getElementById('res-we').textContent=winner.emoji;
  document.getElementById('res-wn').textContent=winner.name.toUpperCase();
  document.getElementById('res-analysis').textContent=analysis;
  document.getElementById('stat-cmp').innerHTML=cmp.map(c=>{
    const aw=c.va>=c.vb;const bw=c.vb>=c.va;
    return `<div class="sc-v l ${aw?'sc-win':'sc-lose'}">${c.labels?c.labels[c.va-1]:c.va}</div><div class="sc-lbl">${c.label}</div><div class="sc-v r ${bw?'sc-win':'sc-lose'}">${c.labels?c.labels[c.vb-1]:c.vb}</div>`;
  }).join('');
  document.getElementById('sim-result').classList.add('show');
}
function resetBattle(){
  picks=[null,null];
  [1,2].forEach(i=>{
    document.getElementById(`slot${i}-ph`).style.display='';
    document.getElementById(`slot${i}-e`).style.display='none';
    document.getElementById(`slot${i}-n`).style.display='none';
    document.getElementById(`slot${i}`).className='sim-slot';
    if(i===2)document.getElementById(`slot${i}`).style.borderColor='';
  });
  document.getElementById('fight-btn').disabled=true;
  document.getElementById('sim-result').classList.remove('show');
  document.getElementById('sim-picker').classList.remove('show');
}
renderPickGrid();

