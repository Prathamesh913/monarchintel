    </div>
  `).join('');
}
function openPicker(slot){
  pickingSlot=slot;
  document.getElementById('picker-label').textContent=`SELECT TITAN ${slot}`;
  document.getElementById('sim-picker').classList.add('show');
  document.getElementById('pick-search').value='';
  renderPickGrid();
}
function filterPicker(){renderPickGrid(document.getElementById('pick-search').value)}
function selectTitan(idx){
  const t=TITANS[idx];picks[pickingSlot-1]=t;
  const slot=document.getElementById(`slot${pickingSlot}`);
  document.getElementById(`slot${pickingSlot}-ph`).style.display='none';
  document.getElementById(`slot${pickingSlot}-e`).textContent=t.emoji;document.getElementById(`slot${pickingSlot}-e`).style.display='block';
  document.getElementById(`slot${pickingSlot}-n`).textContent=t.name;document.getElementById(`slot${pickingSlot}-n`).style.display='block';
  if(pickingSlot===1)slot.classList.add('sel');else{slot.classList.add('sel2');slot.style.borderColor='var(--hostile)';}
  document.getElementById('sim-picker').classList.remove('show');
  if(picks[0]&&picks[1])document.getElementById('fight-btn').disabled=false;
}
function runBattle(){
  const [a,b]=picks;
  const FACTORS={power:0.5,height:0.1,threats:{Omega:4,High:3,Medium:2,Low:1}};
  const scoreA=a.power*FACTORS.power+(parseFloat(a.height)*FACTORS.height)+FACTORS.threats[a.threat]*8+(a.alignment==='alpha'?15:a.alignment==='benevolent'?5:0);
  const scoreB=b.power*FACTORS.power+(parseFloat(b.height)*FACTORS.height)+FACTORS.threats[b.threat]*8+(b.alignment==='alpha'?15:b.alignment==='benevolent'?5:0);
  const winner=scoreA>=scoreB?a:b,loser=scoreA>=scoreB?b:a;
  const margin=Math.abs(scoreA-scoreB);
  const closeness=margin<10?'an extremely close battle — the outcome could go either way in the field':'a decisive engagement';
  const analysis=`Monarch Combat Assessment: Based on biometric data, documented power output, and field engagement records, ${winner.name} holds a tactical advantage over ${loser.name}. ${winner.name}'s ${winner.powers[0].toLowerCase()} capability combined with its ${winner.threat.toLowerCase()}-tier classification gives it the edge in ${closeness}. ${loser.name}'s ${loser.powers[0].toLowerCase()} would be the primary counter-threat. Estimated engagement duration: ${margin<10?'48+ hours':'6–12 hours'}. Monarch recommendation: avoid engagement zone.`;
  const cmp=[
    {label:'POWER INDEX',va:a.power,vb:b.power},
    {label:'THREAT TIER',va:['Low','Medium','High','Omega'].indexOf(a.threat)+1,vb:['Low','Medium','High','Omega'].indexOf(b.threat)+1,labels:['Low','Medium','High','Omega']},
    {label:'HEIGHT',va:parseFloat(a.height),vb:parseFloat(b.height)},
  ];
  document.getElementById('res-we').textContent=winner.emoji;
  document.getElementById('res-wn').textContent=winner.name.toUpperCase();
  document.getElementById('res-analysis').textContent=analysis;
  document.getElementById('stat-cmp').innerHTML=cmp.map(c=>{
    const aw=c.va>=c.vb;const bw=c.vb>=c.va;
    return `<div class="sc-v l ${aw?'sc-win':'sc-lose'}">${c.labels?c.labels[c.va-1]:c.va}</div><div class="sc-lbl">${c.label}</div><div class="sc-v r ${bw?'sc-win':'sc-lose'}">${c.labels?c.labels[c.vb-1]:c.vb}</div>`;
  }).join('');
  document.getElementById('sim-result').classList.add('show');
}
function resetBattle(){
  picks=[null,null];
  [1,2].forEach(i=>{
    document.getElementById(`slot${i}-ph`).style.display='';
    document.getElementById(`slot${i}-e`).style.display='none';
    document.getElementById(`slot${i}-n`).style.display='none';
    document.getElementById(`slot${i}`).className='sim-slot';
    if(i===2)document.getElementById(`slot${i}`).style.borderColor='';
  });
  document.getElementById('fight-btn').disabled=true;
  document.getElementById('sim-result').classList.remove('show');
  document.getElementById('sim-picker').classList.remove('show');
}
renderPickGrid();

// ═══════════════════════════════════════════════════
//  TIMELINE
// ═══════════════════════════════════════════════════
let tlFilter='all';
const typeColors={titan:'var(--threat-omega)',monarch:'var(--monarch)',hollowearth:'var(--sky)',human:'var(--nuclear)'};
function filterTL(btn,type){document.querySelectorAll('#page-timeline .tog').forEach(b=>b.classList.remove('on'));btn.classList.add('on');tlFilter=type;renderTL();}
function renderTL(){
  const data=tlFilter==='all'?TIMELINE:TIMELINE.filter(e=>e.type===tlFilter);
  document.getElementById('tl-count').textContent=data.length+' EVENTS';
  document.getElementById('tl-wrap').innerHTML=data.map(e=>`
    <div class="tlev">
      <div class="tlev-yr">${e.year}</div>
      <div class="tlev-card" style="border-left-color:${typeColors[e.type]||'var(--nuclear)'}">
        <div class="tlev-title">${e.title}</div>
        <div class="tlev-desc">${e.desc}</div>
        <div class="tlev-tags"><span class="ttag" style="border-color:${typeColors[e.type]};color:${typeColors[e.type]}">${e.type.toUpperCase()}</span></div>
      </div>
    </div>
  `).join('');
}
renderTL();

