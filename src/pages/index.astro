<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MonarchIntel — MonsterVerse Titan Intelligence Archive</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&family=Special+Elite&display=swap" rel="stylesheet">
<style is:global>
/* ═══════════════════════════════════════
   MONARCHINTEL — COMPLETE DESIGN SYSTEM
═══════════════════════════════════════ */
:root {
  --void:#020608; --deep:#040a0e; --surface:#091318; --surface-2:#0c1a24; --surface-3:#0f2030;
  --border:#152535; --border-2:#1e3a55; --border-3:#2a5070;
  --text:#c0d8e8; --text-2:#7a9ab0; --muted:#4a6878; --inverse:#040a0e;
  --nuclear:#00ff88; --nuclear-2:#00cc66; --nuclear-glow:rgba(0,255,136,0.12);
  --monarch:#e8b400; --monarch-2:#a07800; --sky:#00aaff;
  --alive:#00ff88; --dormant:#e8b400; --deceased:#4a6878; --unknown:#00aaff;
  --threat-low:#00ff88; --threat-med:#ffaa00; --threat-high:#ff6600; --threat-omega:#ff0055;
  --alpha:#ff4444; --hostile:#ff4d00; --benevolent:#00ff88; --neutral:#4a6878;
  --era-mv:#0099ff; --era-showa:#ff88aa; --era-heisei:#e8b400; --era-millennium:#aa44ff; --era-reiwa:#00ff88; --era-animation:#00ccff;
  --paper:#f0e8d0; --paper-2:#e8dfc4; --ink:#1a1008; --stamp-red:#8b1a1a; --stamp-blue:#0a2a5e;
  --font-display:'Bebas Neue',sans-serif;
  --font-serif:'DM Serif Display',serif;
  --font-ui:'Rajdhani',sans-serif;
  --font-mono:'Share Tech Mono',monospace;
  --font-doc:'Special Elite',monospace;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--deep);color:var(--text);font-family:var(--font-ui);overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:9999;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.015) 3px,rgba(0,0,0,0.015) 4px)}
::-webkit-scrollbar{width:5px;height:5px}::-webkit-scrollbar-track{background:var(--void)}::-webkit-scrollbar-thumb{background:var(--border-2)}::-webkit-scrollbar-thumb:hover{background:var(--nuclear)}

/* ── MASTHEAD ── */
.masthead{position:fixed;top:0;left:0;right:0;z-index:1000;height:58px;background:rgba(2,6,8,0.97);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 1.5rem;gap:0}
.mast-brand{display:flex;flex-direction:column;margin-right:2rem;cursor:pointer;flex-shrink:0}
.mast-name{font-family:var(--font-display);font-size:1.5rem;letter-spacing:4px;line-height:1}
.mast-name .mo{color:var(--nuclear);text-shadow:0 0 15px rgba(0,255,136,0.3)}
.mast-name .in{color:#fff}
.mast-sub{font-family:var(--font-mono);font-size:0.46rem;color:var(--muted);letter-spacing:3px;margin-top:1px}
.mast-nav{display:flex;gap:0;overflow-x:auto}
.mast-nav::-webkit-scrollbar{display:none}
.mnav{height:58px;padding:0 0.95rem;background:none;border:none;color:var(--muted);font-family:var(--font-ui);font-size:0.78rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all 0.2s}
.mnav:hover,.mnav.on{color:var(--nuclear);border-bottom-color:var(--nuclear)}
.mast-right{margin-left:auto;display:flex;align-items:center;gap:1rem;flex-shrink:0}
.mast-tag{font-family:var(--font-mono);font-size:0.52rem;color:var(--monarch);border:1px solid var(--monarch-2);padding:0.22rem 0.6rem;letter-spacing:2px;animation:blinktag 4s infinite}
@keyframes blinktag{0%,90%,100%{opacity:1}95%{opacity:0.4}}

/* ── INTEL TICKER ── */
.ticker{background:var(--surface);border-bottom:1px solid var(--border);overflow:hidden;height:34px;display:flex;align-items:center}
.ticker-tag{font-family:var(--font-mono);font-size:0.58rem;background:var(--nuclear);color:var(--inverse);padding:0 1rem;height:100%;display:flex;align-items:center;letter-spacing:3px;white-space:nowrap;flex-shrink:0}
.ticker-track{flex:1;overflow:hidden;position:relative;height:100%}
.ticker-inner{display:flex;align-items:center;height:100%;gap:3rem;animation:tickscroll 40s linear infinite;width:max-content;padding-left:2rem}
@keyframes tickscroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.ticker-item{display:flex;align-items:center;gap:0.5rem;white-space:nowrap}
.ticker-dot{width:4px;height:4px;background:var(--nuclear);flex-shrink:0}
.ticker-text{font-family:var(--font-mono);font-size:0.58rem;color:var(--text-2);letter-spacing:1px}

/* ── PAGES ── */
.page{display:none;padding-top:58px}
.page.on{display:block}

/* ── HERO ── */
.hero{min-height:calc(100vh - 58px);display:grid;grid-template-columns:1fr 400px;gap:5rem;align-items:center;max-width:1400px;margin:0 auto;padding:5rem 2rem;position:relative}
@media(max-width:1000px){.hero{grid-template-columns:1fr;padding:3rem 1.5rem}}
.hero-bg{position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 60% 50% at 25% 50%,rgba(0,255,136,0.04),transparent 65%),
  radial-gradient(ellipse 40% 60% at 75% 30%,rgba(0,170,255,0.035),transparent 65%),
  radial-gradient(ellipse 35% 45% at 60% 80%,rgba(255,77,0,0.03),transparent 60%)}
.hero-grid-bg{position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:linear-gradient(rgba(0,255,136,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,136,0.018) 1px,transparent 1px);
  background-size:100px 100px;animation:gridflow 35s linear infinite}
@keyframes gridflow{0%{transform:translateY(0)}100%{transform:translateY(100px)}}
.hero-accent-line{position:fixed;left:0;top:58px;bottom:0;width:3px;background:linear-gradient(to bottom,transparent,var(--nuclear) 20%,var(--nuclear) 80%,transparent);opacity:0.3;pointer-events:none;z-index:0}
.hero-left{position:relative;z-index:1}
.hero-eye{font-family:var(--font-mono);font-size:0.62rem;color:var(--nuclear);letter-spacing:5px;margin-bottom:1.5rem;display:flex;align-items:center;gap:0.7rem;opacity:0;animation:fadeup 0.7s 0.2s forwards}
.hero-eye::before{content:'';width:28px;height:1px;background:var(--nuclear)}
.hero-title{font-family:var(--font-display);line-height:0.88;letter-spacing:-1px;margin-bottom:1.2rem;opacity:0;animation:fadeup 0.7s 0.4s forwards}
.hero-title .l1{font-size:clamp(4rem,10vw,9rem);background:linear-gradient(155deg,#fff 0%,#8bbdd4 55%,#2a6080 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:block}
.hero-title .l2{font-size:clamp(4rem,10vw,9rem);background:linear-gradient(155deg,var(--nuclear) 0%,var(--nuclear-2) 55%,#004433 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:block;filter:drop-shadow(0 0 30px rgba(0,255,136,0.18))}
.hero-deck{font-family:var(--font-serif);font-style:italic;font-size:1.2rem;color:var(--text-2);line-height:1.7;max-width:540px;margin-bottom:2.5rem;opacity:0;animation:fadeup 0.7s 0.6s forwards}
.hero-counters{display:flex;gap:2.5rem;margin-bottom:2.5rem;opacity:0;animation:fadeup 0.7s 0.8s forwards;flex-wrap:wrap}
.hcounter{}.hcn{font-family:var(--font-display);font-size:2.8rem;color:var(--nuclear);line-height:1;text-shadow:0 0 20px rgba(0,255,136,0.25);display:block}
.hcl{font-family:var(--font-mono);font-size:0.58rem;color:var(--muted);letter-spacing:3px;margin-top:0.1rem;display:block}
.hero-btns{display:flex;gap:0.8rem;flex-wrap:wrap;opacity:0;animation:fadeup 0.7s 1s forwards}
@keyframes fadeup{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* Featured Titan */
.feat-titan{position:relative;z-index:1;background:var(--surface);border:1px solid var(--border-2);overflow:hidden;opacity:0;animation:fadeup 0.7s 0.6s forwards}
.feat-titan::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--nuclear),transparent)}
.ft-head{background:linear-gradient(135deg,rgba(0,255,136,0.07),rgba(0,170,255,0.04));border-bottom:1px solid var(--border);padding:0.9rem 1.5rem;display:flex;justify-content:space-between;align-items:center}
.ft-head-lbl{font-family:var(--font-mono);font-size:0.58rem;color:var(--nuclear);letter-spacing:3px}
.ft-head-date{font-family:var(--font-mono);font-size:0.58rem;color:var(--muted);letter-spacing:2px}
.ft-body{padding:1.5rem}
.ft-emoji{font-size:5.5rem;display:block;text-align:center;margin:0.5rem 0 1rem;filter:drop-shadow(0 6px 20px rgba(0,0,0,0.5));animation:floatfeat 5s ease-in-out infinite}
@keyframes floatfeat{0%,100%{transform:translateY(0)}50%{transform:translateY(-9px)}}
.ft-name{font-family:var(--font-display);font-size:2.8rem;color:#fff;letter-spacing:3px;line-height:1}
.ft-alias{font-family:var(--font-mono);font-size:0.58rem;color:var(--muted);letter-spacing:2px;margin-top:0.25rem}
.ft-pull{font-family:var(--font-serif);font-style:italic;font-size:0.92rem;color:var(--text-2);line-height:1.7;margin:1rem 0;padding:0.8rem 1rem;border-left:2px solid var(--nuclear);background:rgba(0,255,136,0.03)}
.ft-pull-attr{font-family:var(--font-mono);font-size:0.52rem;color:var(--muted);letter-spacing:2px;margin-top:0.4rem;font-style:normal}
.ft-badges{display:flex;gap:0.4rem;flex-wrap:wrap;margin-top:1rem}
.ft-foot{border-top:1px solid var(--border);padding:0.75rem 1.5rem;display:flex;justify-content:space-between;align-items:center}
.ft-foot-data{font-family:var(--font-mono);font-size:0.55rem;color:var(--muted);letter-spacing:1px}
.ft-cta{font-family:var(--font-mono);font-size:0.6rem;color:var(--nuclear);letter-spacing:2px;cursor:pointer;transition:opacity 0.2s}
.ft-cta:hover{opacity:0.7}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;gap:0.5rem;font-family:var(--font-display);letter-spacing:3px;cursor:pointer;border:none;transition:all 0.2s;font-size:1rem}
.btn-p{background:var(--nuclear);color:var(--inverse);padding:0.82rem 2.2rem;clip-path:polygon(8px 0,100% 0,calc(100% - 8px) 100%,0 100%)}
.btn-p:hover{background:#fff;transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,255,136,0.2)}
.btn-s{background:transparent;color:var(--text);border:1px solid var(--border-2) !important;padding:0.82rem 2.2rem;clip-path:none}
.btn-s:hover{border-color:var(--nuclear) !important;color:var(--nuclear)}
.btn-g{background:transparent;color:var(--muted);border:1px solid var(--border) !important;padding:0.65rem 1.4rem;font-family:var(--font-mono);letter-spacing:2px;font-size:0.7rem;clip-path:none}
.btn-g:hover{border-color:var(--nuclear) !important;color:var(--nuclear)}

/* ── BADGES ── */
.badge{display:inline-flex;align-items:center;font-family:var(--font-mono);font-size:0.58rem;letter-spacing:2px;text-transform:uppercase;padding:0.18rem 0.6rem;border:1px solid;line-height:1.5}
.b-nuc{border-color:var(--nuclear);color:var(--nuclear);background:rgba(0,255,136,0.07)}
.b-mon{border-color:var(--monarch);color:var(--monarch);background:rgba(232,180,0,0.07)}
.b-sky{border-color:var(--sky);color:var(--sky);background:rgba(0,170,255,0.07)}
.b-lava{border-color:var(--hostile);color:var(--hostile);background:rgba(255,77,0,0.07)}
.b-mut{border-color:var(--border-2);color:var(--muted)}
.b-omg{border-color:var(--threat-omega);color:var(--threat-omega);background:rgba(255,0,85,0.07);animation:omg 2s infinite}
@keyframes omg{0%,100%{box-shadow:0 0 0 rgba(255,0,85,0)}50%{box-shadow:0 0 10px rgba(255,0,85,0.35)}}
.b-sm{font-size:0.52rem;padding:0.12rem 0.45rem}
.b-lg{font-size:0.65rem;padding:0.28rem 0.85rem}

/* ── SECTION COMMON ── */
.sec{max-width:1400px;margin:0 auto;padding:4.5rem 2rem}
.sec-head{display:flex;align-items:baseline;gap:1rem;margin-bottom:1rem;padding-bottom:1rem;border-bottom:1px solid var(--border);flex-wrap:wrap}
.sec-title{font-family:var(--font-display);font-size:2.2rem;color:#fff;letter-spacing:2px}
.sec-code{font-family:var(--font-mono);font-size:0.62rem;color:var(--nuclear);letter-spacing:3px}
.sec-count{margin-left:auto;font-family:var(--font-mono);font-size:0.62rem;color:var(--muted)}
.sec-deck{font-family:var(--font-serif);font-style:italic;font-size:1.05rem;color:var(--text-2);line-height:1.7;margin-bottom:2rem;max-width:700px}
.divider{height:1px;background:linear-gradient(90deg,transparent,var(--border-2),transparent);margin:0 2rem}

/* ── CONTROLS ── */
.ctrl{display:flex;gap:0.5rem;margin-bottom:1.5rem;flex-wrap:wrap;align-items:center}
.tog{background:transparent;border:1px solid var(--border);color:var(--muted);padding:0.42rem 1rem;font-family:var(--font-ui);font-size:0.75rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all 0.2s}
.tog:hover,.tog.on{background:rgba(0,255,136,0.07);border-color:var(--nuclear);color:var(--nuclear)}
.tog.mon:hover,.tog.mon.on{background:rgba(232,180,0,0.07);border-color:var(--monarch);color:var(--monarch)}
.srchwrap{position:relative;flex:1;min-width:180px}
.srchwrap::before{content:'⌕';position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:1rem;pointer-events:none}
.srch{width:100%;background:var(--surface);border:1px solid var(--border);color:var(--text);padding:0.42rem 0.9rem 0.42rem 2.1rem;font-family:var(--font-mono);font-size:0.7rem;letter-spacing:1px;outline:none;transition:border-color 0.2s}
.srch:focus{border-color:var(--nuclear);background:var(--surface-3)}
.fsel{background:var(--surface);border:1px solid var(--border);color:var(--text);padding:0.42rem 0.9rem;font-family:var(--font-mono);font-size:0.65rem;letter-spacing:1px;outline:none;cursor:pointer}
.fsel:focus{border-color:var(--nuclear)}

/* ── CONTENT GRID (HOME) ── */
.home-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:var(--border)}
@media(max-width:900px){.home-grid{grid-template-columns:1fr}}
.hg-item{background:var(--void);padding:2.5rem;transition:background 0.2s;cursor:pointer;position:relative;overflow:hidden}
.hg-item::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--item-color,var(--nuclear)),transparent);opacity:0;transition:opacity 0.2s}
.hg-item:hover{background:var(--surface)}
.hg-item:hover::after{opacity:1}
.hg-num{font-family:var(--font-display);font-size:4.5rem;color:var(--border-2);line-height:1;margin-bottom:1rem;transition:color 0.2s;display:block}
.hg-item:hover .hg-num{color:var(--nuclear);text-shadow:0 0 20px rgba(0,255,136,0.2)}
.hg-title{font-family:var(--font-display);font-size:1.6rem;color:#fff;letter-spacing:2px;margin-bottom:0.5rem}
.hg-deck{font-family:var(--font-serif);font-style:italic;font-size:0.92rem;color:var(--text-2);line-height:1.65;margin-bottom:1rem}
.hg-meta{font-family:var(--font-mono);font-size:0.58rem;color:var(--muted);letter-spacing:2px}
.hg-wide{grid-column:1/-1;background:linear-gradient(135deg,rgba(0,255,136,0.04),rgba(0,170,255,0.03));border-top:1px solid var(--border)}

/* ── TITAN MINI STRIP ── */
.tmini-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1px;background:var(--border)}
.tmini{background:var(--surface);padding:1.1rem;cursor:pointer;transition:all 0.2s;border-top:2px solid transparent;display:flex;flex-direction:column;gap:0.25rem}
.tmini:hover{background:var(--surface-2);border-top-color:var(--nuclear)}
.tmini-e{font-size:1.8rem}
.tmini-n{font-family:var(--font-display);font-size:1.1rem;color:#fff;letter-spacing:2px;line-height:1}
.tmini-s{font-family:var(--font-mono);font-size:0.52rem;color:var(--muted);letter-spacing:2px}
.tmini-more{align-items:center;justify-content:center;border-top-color:transparent !important}
.tmini-more:hover{border-top-color:var(--nuclear) !important}

/* ── WATCH ORDER ── */
.wo-list{display:flex;flex-direction:column;gap:1px}
.wo-item{display:grid;grid-template-columns:52px 44px 1fr 80px;gap:1rem;align-items:center;padding:1rem 1.2rem;background:var(--surface);border:1px solid transparent;border-left:3px solid transparent;cursor:pointer;transition:all 0.2s}
.wo-item:hover{background:var(--surface-2);border-color:var(--border);border-left-color:var(--nuclear)}
.wo-item.open{background:var(--surface-2);border-color:var(--border);border-left-color:var(--nuclear)}
.wo-num{font-family:var(--font-display);font-size:1.6rem;color:var(--border-2);text-align:center;transition:all 0.2s}
.wo-item:hover .wo-num,.wo-item.open .wo-num{color:var(--nuclear);text-shadow:0 0 12px var(--nuclear)}
.wo-icon{width:44px;height:44px;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.wo-body{min-width:0}
.wo-title{font-size:1.05rem;font-weight:700;color:#fff;letter-spacing:0.5px}
.wo-meta{display:flex;gap:0.7rem;margin-top:0.22rem;align-items:center;flex-wrap:wrap}
.wo-year{font-family:var(--font-mono);font-size:0.62rem;color:var(--muted)}
.epill{font-family:var(--font-mono);font-size:0.52rem;letter-spacing:2px;padding:0.1rem 0.5rem;border:1px solid;text-transform:uppercase}
.e-mv{border-color:var(--era-mv);color:var(--era-mv)}
.e-showa{border-color:var(--era-showa);color:var(--era-showa)}
.e-heisei{border-color:var(--era-heisei);color:var(--era-heisei)}
.e-millennium{border-color:var(--era-millennium);color:var(--era-millennium)}
.e-reiwa{border-color:var(--era-reiwa);color:var(--era-reiwa)}
.e-animation{border-color:var(--era-animation);color:var(--era-animation)}
.wo-chips{display:flex;gap:0.25rem;flex-wrap:wrap;margin-top:0.3rem}
.wo-chip{font-family:var(--font-mono);font-size:0.52rem;background:rgba(0,255,136,0.06);border:1px solid rgba(0,255,136,0.16);color:var(--nuclear);padding:0.08rem 0.4rem}
.wo-right{text-align:right}
.wo-score{font-family:var(--font-display);font-size:1.4rem;color:var(--monarch);line-height:1}
.wo-plat{font-family:var(--font-mono);font-size:0.56rem;color:var(--muted);margin-top:0.15rem}
.wo-expand{display:none;grid-column:1/-1;border-top:1px solid var(--border);padding-top:1rem;margin-top:0.5rem}
.wo-expand.show{display:block}
.wo-exp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:0.7rem;margin-bottom:0.8rem}
.wo-ef label{font-family:var(--font-mono);font-size:0.56rem;color:var(--muted);letter-spacing:2px;display:block;margin-bottom:0.15rem}
.wo-ef span{font-size:0.88rem;font-weight:600}
.wo-syn{font-family:var(--font-serif);font-style:italic;font-size:0.92rem;color:var(--text-2);line-height:1.7}

/* ── TITANDEX ── */
.tdex-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1px;background:var(--border)}
.tcard{background:var(--surface);border:1px solid transparent;padding:1.4rem;cursor:pointer;transition:all 0.25s;position:relative;overflow:hidden}
.tcard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--ca,var(--nuclear)),transparent);opacity:0;transition:opacity 0.2s}
.tcard:hover{background:var(--surface-2);border-color:var(--border-2);transform:translateY(-3px);box-shadow:0 12px 32px rgba(0,0,0,0.4)}
.tcard:hover::before{opacity:1}
.tcard[data-a="alpha"]{--ca:var(--alpha)}
.tcard[data-a="hostile"]{--ca:var(--hostile)}
.tcard[data-a="benevolent"]{--ca:var(--benevolent)}
.tcard[data-a="neutral"]{--ca:var(--neutral)}
.tcard[data-a="unknown"]{--ca:var(--sky)}
.tc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.6rem}
.tc-id{font-family:var(--font-mono);font-size:0.56rem;color:var(--muted);letter-spacing:2px}
.tc-emoji{font-size:2.6rem;margin:0.4rem 0;line-height:1;filter:drop-shadow(0 4px 10px rgba(0,0,0,0.5))}
.tc-name{font-family:var(--font-display);font-size:1.5rem;color:#fff;letter-spacing:2px;line-height:1}
.tc-alias{font-family:var(--font-mono);font-size:0.56rem;color:var(--muted);letter-spacing:1px;margin-top:0.15rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tc-div{height:1px;background:var(--border);margin:0.85rem 0}
.tc-stats{display:grid;grid-template-columns:1fr 1fr;gap:0.45rem}
.tcs label{font-family:var(--font-mono);font-size:0.5rem;color:var(--muted);letter-spacing:2px;display:block}
.tcs span{font-size:0.8rem;font-weight:700}
.al-alpha{color:var(--alpha)}.al-hostile{color:var(--hostile)}.al-benevolent{color:var(--benevolent)}.al-neutral{color:var(--neutral)}.al-unknown{color:var(--sky)}
.st-alive{color:var(--alive)}.st-dormant{color:var(--dormant)}.st-deceased{color:var(--deceased)}.st-unknown{color:var(--unknown)}
.tl-low{border-color:var(--threat-low);color:var(--threat-low)}.tl-medium{border-color:var(--threat-med);color:var(--threat-med)}.tl-high{border-color:var(--threat-high);color:var(--threat-high)}.tl-omega{border-color:var(--threat-omega);color:var(--threat-omega);animation:omg 2s infinite}
.tc-pbar{display:flex;gap:2px;margin-top:0.8rem}
.tcpb{height:3px;flex:1;background:var(--border)}
.tcpb.on{background:var(--nuclear);box-shadow:0 0 4px var(--nuclear)}
.tc-hint{font-family:var(--font-mono);font-size:0.52rem;color:var(--muted);letter-spacing:2px;margin-top:0.7rem;text-align:center;opacity:0;transition:opacity 0.2s}
.tcard:hover .tc-hint{opacity:1}

/* ── MODAL ── */
.moverlay{position:fixed;inset:0;background:rgba(2,6,8,0.96);z-index:3000;display:none;align-items:center;justify-content:center;padding:1rem;backdrop-filter:blur(8px)}
.moverlay.open{display:flex;animation:mopen 0.25s ease}
@keyframes mopen{from{opacity:0;transform:scale(0.96)}to{opacity:1;transform:scale(1)}}
.modal{background:var(--surface);border:1px solid var(--border-2);width:100%;max-width:880px;max-height:92vh;overflow-y:auto}
.mhd{display:flex;align-items:flex-start;gap:1.5rem;padding:1.5rem;background:var(--surface-2);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:10}
.mhd-info{flex:1}
.mid-lbl{font-family:var(--font-mono);font-size:0.58rem;color:var(--muted);letter-spacing:3px;margin-bottom:0.25rem}
.mhd-name{font-family:var(--font-display);font-size:2.2rem;color:#fff;letter-spacing:3px;line-height:1}
.mhd-alias{font-family:var(--font-mono);font-size:0.62rem;color:var(--muted);letter-spacing:2px;margin-top:0.2rem}
.mclose{background:none;border:1px solid var(--border);color:var(--muted);width:34px;height:34px;cursor:pointer;font-size:0.85rem;transition:all 0.2s;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.mclose:hover{border-color:var(--hostile);color:var(--hostile)}
.mbody{padding:1.5rem;display:grid;grid-template-columns:190px 1fr;gap:1.5rem}
@media(max-width:600px){.mbody{grid-template-columns:1fr}}
.mdisp{background:var(--deep);border:1px solid var(--border);padding:1.5rem;text-align:center;display:flex;flex-direction:column;align-items:center;gap:0.5rem}
.memoji{font-size:5rem;filter:drop-shadow(0 0 20px rgba(0,255,136,0.12));animation:floatfeat 4s ease-in-out infinite}
.mright{display:flex;flex-direction:column;gap:0.8rem}
.mstats{background:var(--deep);border:1px solid var(--border);padding:1rem}
.msr{display:flex;justify-content:space-between;padding:0.5rem 0;border-bottom:1px solid var(--border);gap:1rem}
.msr:last-child{border-bottom:none}
.msr label{font-family:var(--font-mono);font-size:0.56rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;flex-shrink:0}
.msr .v{font-size:0.88rem;font-weight:600;text-align:right}
.mblock{background:var(--deep);border:1px solid var(--border);padding:1rem;grid-column:1/-1}
.mblock-t{font-family:var(--font-display);font-size:1rem;letter-spacing:3px;color:var(--nuclear);margin-bottom:0.7rem}
.mtags{display:flex;gap:0.4rem;flex-wrap:wrap}
.ptag{background:rgba(0,255,136,0.06);border:1px solid rgba(0,255,136,0.18);color:var(--nuclear);font-family:var(--font-mono);font-size:0.58rem;letter-spacing:1px;padding:0.22rem 0.65rem}
.atag{background:rgba(232,180,0,0.06);border:1px solid rgba(232,180,0,0.18);color:var(--monarch);font-family:var(--font-mono);font-size:0.58rem;letter-spacing:1px;padding:0.22rem 0.65rem}

/* ── EPISODES ── */
.show-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:1.5rem;overflow-x:auto}
.show-tabs::-webkit-scrollbar{display:none}
.stab{background:none;border:none;color:var(--muted);font-family:var(--font-ui);font-size:0.78rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;padding:0.8rem 1.5rem;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all 0.2s}
.stab:hover,.stab.on{color:var(--nuclear);border-bottom-color:var(--nuclear)}
.ep-list{display:flex;flex-direction:column;gap:1px}
.ep-item{display:grid;grid-template-columns:50px 1fr;gap:1rem;align-items:start;padding:1rem 1.2rem;background:var(--surface);border:1px solid transparent;border-left:3px solid transparent;cursor:pointer;transition:all 0.2s}
.ep-item:hover{background:var(--surface-2);border-color:var(--border);border-left-color:var(--monarch)}
.ep-item.open{background:var(--surface-2);border-left-color:var(--monarch);border-color:var(--border)}
.ep-num{font-family:var(--font-display);font-size:1.5rem;color:var(--border-2);text-align:center;transition:color 0.2s}
.ep-item:hover .ep-num,.ep-item.open .ep-num{color:var(--monarch)}
.ep-title{font-size:1rem;font-weight:700;color:#fff}
.ep-air{font-family:var(--font-mono);font-size:0.58rem;color:var(--muted);letter-spacing:2px;margin-top:0.2rem}
.ep-titans{display:flex;gap:0.3rem;flex-wrap:wrap;margin-top:0.35rem}
.ep-tag{font-family:var(--font-mono);font-size:0.52rem;background:rgba(232,180,0,0.06);border:1px solid rgba(232,180,0,0.18);color:var(--monarch);padding:0.08rem 0.4rem}
.ep-expand{display:none;grid-column:1/-1;border-top:1px solid var(--border);padding-top:0.8rem;margin-top:0.6rem}
.ep-expand.show{display:block}
.ep-syn{font-family:var(--font-serif);font-style:italic;font-size:0.9rem;color:var(--text-2);line-height:1.7}

/* ── SIZE CHART ── */
.size-wrap{background:var(--surface);border:1px solid var(--border);padding:2rem;overflow-x:auto}
.size-bars{display:flex;align-items:flex-end;gap:4px;height:300px;border-bottom:1px solid var(--border-2);min-width:600px;padding-bottom:0}
.sbar-col{display:flex;flex-direction:column;align-items:center;flex:1;height:100%;justify-content:flex-end}
.sbar-val{font-family:var(--font-mono);font-size:0.5rem;color:var(--nuclear);margin-bottom:0.3rem;text-align:center}
.sbar{width:100%;transition:height 1.2s cubic-bezier(0.34,1.56,0.64,1);min-width:28px}
.sbar-inner{width:100%;height:100%;background:linear-gradient(to top,var(--nuclear-2),var(--nuclear));opacity:0.75;position:relative}
.sbar-inner::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:#fff;box-shadow:0 0 8px var(--nuclear)}
.sbar:hover .sbar-inner{opacity:1}
.sbar-label{font-family:var(--font-mono);font-size:0.48rem;color:var(--muted);letter-spacing:1px;margin-top:0.6rem;text-align:center;transform:rotate(-40deg);transform-origin:top center;white-space:nowrap}
.size-legend{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.5rem;margin-top:1.5rem}
.sleg{display:flex;align-items:center;gap:0.7rem;padding:0.35rem}
.sleg-bar{width:10px;height:10px;background:var(--nuclear);flex-shrink:0}
.sleg-info{font-family:var(--font-mono);font-size:0.58rem;color:var(--text-2)}
.sleg-info span{color:var(--nuclear)}

/* ── RELATION WEB ── */
#relcanvas{width:100%;height:520px;background:var(--surface);border:1px solid var(--border);cursor:grab;display:block}
#relcanvas:active{cursor:grabbing}
.rel-leg{display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:1rem}
.rleg{display:flex;align-items:center;gap:0.5rem;font-family:var(--font-mono);font-size:0.6rem;color:var(--muted);letter-spacing:1px}
.rleg-line{width:28px;height:2px}

/* ── BATTLE SIM ── */
.sim-layout{display:grid;grid-template-columns:1fr auto 1fr;gap:1.5rem;align-items:start}
@media(max-width:700px){.sim-layout{grid-template-columns:1fr}}
.sim-slot{background:var(--surface);border:1px solid var(--border);padding:1.5rem;text-align:center;cursor:pointer;transition:all 0.2s;min-height:220px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.5rem}
.sim-slot:hover,.sim-slot.sel{border-color:var(--nuclear);background:var(--surface-2)}
.sim-slot.sel2{border-color:var(--hostile) !important}
.sim-ph{font-family:var(--font-mono);font-size:0.65rem;color:var(--muted);letter-spacing:3px}
.sim-emoji{font-size:4rem;filter:drop-shadow(0 4px 14px rgba(0,0,0,0.5))}
.sim-name{font-family:var(--font-display);font-size:1.5rem;color:#fff;letter-spacing:2px}
.sim-mid{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem}
.vs-txt{font-family:var(--font-display);font-size:3.5rem;color:var(--hostile);text-shadow:0 0 20px var(--hostile)}
.fight-btn{background:var(--hostile);color:#fff;border:none;padding:0.85rem 2rem;font-family:var(--font-display);font-size:1.1rem;letter-spacing:4px;cursor:pointer;clip-path:polygon(6px 0,100% 0,calc(100% - 6px) 100%,0 100%);transition:all 0.2s}
.fight-btn:hover:not(:disabled){background:#ff7744;transform:scale(1.04)}
.fight-btn:disabled{opacity:0.4;cursor:not-allowed}
.sim-picker{background:var(--surface);border:1px solid var(--border);padding:1rem;margin-bottom:1rem;display:none}
.sim-picker.show{display:block}
.pick-lbl{font-family:var(--font-mono);font-size:0.62rem;color:var(--nuclear);letter-spacing:3px;margin-bottom:0.7rem}
.pick-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:0.5rem;max-height:260px;overflow-y:auto;margin-top:0.7rem}
.pick-card{background:var(--surface-2);border:1px solid var(--border);padding:0.65rem;text-align:center;cursor:pointer;transition:all 0.15s}
.pick-card:hover{border-color:var(--nuclear);background:var(--surface-3)}
.pick-e{font-size:1.8rem}
.pick-n{font-family:var(--font-ui);font-size:0.75rem;font-weight:700;color:#fff;margin-top:0.2rem}
.sim-result{margin-top:1.5rem;background:var(--surface-2);border:1px solid var(--border-2);padding:1.5rem;display:none}
.sim-result.show{display:block;animation:fadeup 0.4s ease}
.res-h{font-family:var(--font-display);font-size:1.8rem;color:var(--nuclear);letter-spacing:3px;margin-bottom:1rem;text-align:center}
.res-winner{text-align:center;margin-bottom:1rem}
.res-we{font-size:3rem}
.res-wn{font-family:var(--font-display);font-size:2.2rem;color:#fff;letter-spacing:3px}
.res-wl{font-family:var(--font-mono);font-size:0.62rem;color:var(--nuclear);letter-spacing:3px;margin-top:0.2rem}
.res-analysis{font-family:var(--font-serif);font-style:italic;font-size:0.95rem;color:var(--text-2);line-height:1.75;margin-top:1rem;padding:1rem;border-left:2px solid var(--nuclear);background:rgba(0,255,136,0.03)}
.stat-cmp{display:grid;grid-template-columns:1fr auto 1fr;gap:0.4rem;margin-top:1.2rem}
.sc-v{padding:0.4rem;font-size:0.85rem;font-weight:700}.sc-v.l{text-align:right}.sc-v.r{text-align:left}
.sc-lbl{font-family:var(--font-mono);font-size:0.58rem;color:var(--muted);text-align:center;padding:0.4rem;letter-spacing:2px}
.sc-win{color:var(--nuclear)}.sc-lose{color:var(--muted)}

/* ── MONARCH TIMELINE ── */
.tl-wrap{position:relative;padding-left:2rem}
.tl-wrap::before{content:'';position:absolute;left:0;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,transparent,var(--border-2) 5%,var(--border-2) 95%,transparent)}
.tlev{position:relative;padding:0 0 2.5rem 2rem}
.tlev::before{content:'';position:absolute;left:-4px;top:8px;width:9px;height:9px;background:var(--nuclear);border:2px solid var(--deep);border-radius:50%;box-shadow:0 0 8px var(--nuclear)}
.tlev-yr{font-family:var(--font-display);font-size:1.05rem;color:var(--nuclear);letter-spacing:3px;margin-bottom:0.4rem}
.tlev-card{background:var(--surface);border:1px solid var(--border);padding:1rem 1.2rem;border-left:3px solid}
.tlev-title{font-size:0.95rem;font-weight:700;color:#fff;margin-bottom:0.3rem}
.tlev-desc{font-family:var(--font-serif);font-style:italic;font-size:0.88rem;color:var(--text-2);line-height:1.65}
.tlev-tags{display:flex;gap:0.4rem;flex-wrap:wrap;margin-top:0.6rem}
.ttag{font-family:var(--font-mono);font-size:0.52rem;padding:0.12rem 0.5rem;border:1px solid}

/* ── FOOTER ── */
