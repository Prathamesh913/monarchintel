let sizeFilter='all';
function filterSize(btn,f){document.querySelectorAll('#page-sizechart .tog').forEach(b=>b.classList.remove('on'));btn.classList.add('on');sizeFilter=f;renderSize(SIZES);}
function renderSize(data){
  const filtered = sizeFilter==='all'?data:sizeFilter==='monsterverse'?data.filter(s=>s.era==='monsterverse'):data.filter(s=>s.type===sizeFilter);
  const sorted = [...filtered].sort((a,b)=>b.height-a.height);
  const max = sorted[0]?.height||300;
  document.getElementById('size-bars').innerHTML=sorted.map(s=>`
    <div class="sbar-col">
      <div class="sbar-val">${s.height}m</div>
      <div class="sbar" style="height:${Math.max((s.height/max)*100,1)}%">
        <div class="sbar-inner" style="${s.type==='aerial'?'background:linear-gradient(to top,var(--sky),rgba(0,170,255,0.4))':s.type==='aquatic'?'background:linear-gradient(to top,#0055aa,#0099ff)':''}"></div>
      </div>
      <div class="sbar-label">${s.emoji} ${s.name}</div>
    </div>
  `).join('');
  document.getElementById('size-legend').innerHTML=sorted.map(s=>`
