      // ── Slot content renderer ──
      function slotContent(t, slot) {
        const accentColor = slot === 1 ? "var(--nuclear)" : "var(--hostile)";
        const tagClass = slot === 1 ? "" : " r2";
        const threatColors = {
          omega: "var(--threat-omega)",
          high: "var(--threat-high)",
          medium: "var(--threat-med)",
          low: "var(--threat-low)",
        };
        const tc = threatColors[t.threat.toLowerCase()] || "var(--nuclear)";
        const maxShow = 6;
        const shown = t.powers.slice(0, maxShow);
        const extra = t.powers.length - maxShow;
        const powerChips = shown
          .map(
            (p) =>
              `<div class="sim-power-tag${tagClass}"><span class="pow-icon">${getPowerIcon(p)}</span>${p}</div>`,
          )
          .join("");
        const moreChip =
          extra > 0 ? `<div class="sim-power-more">+${extra} MORE</div>` : "";
        return `
    <div class="sim-emoji">${t.emoji}</div>
    <div class="sim-name">${t.name}</div>
    <div class="sim-alias">${t.alias.split("/")[0].trim()}</div>
    <div class="sim-slot-badge" style="margin-top:0.7rem">
      <span class="badge b-sm" style="border-color:${tc};color:${tc}">${t.threat.toUpperCase()}</span>
      <span class="badge b-sm" style="border-color:${accentColor};color:${accentColor}">${t.align.toUpperCase()}</span>
    </div>
    <div class="sim-powers">${powerChips}${moreChip}</div>
    <div class="sim-change">CLICK TO CHANGE</div>
  `;
      }

      // ── Picker ──
      function renderPickGrid(query = "") {
        const f = TITANS.filter(
          (t) =>
            t.name.toLowerCase().includes(query.toLowerCase()) ||
            t.alias.toLowerCase().includes(query.toLowerCase()),
        );
        document.getElementById("pick-grid").innerHTML = f
          .map((t) => {
            const threat = t.threat.toLowerCase();
            const threatColors = {
              omega: "var(--threat-omega)",
              high: "var(--threat-high)",
              medium: "var(--threat-med)",
              low: "var(--threat-low)",
            };
            return `
      <div class="pick-card" onclick="selectTitan('${t.id}')">
        <div class="pick-e">${t.emoji}</div>
        <div class="pick-n">${t.name}</div>
        <div class="pick-t" style="color:${threatColors[threat]}">${threat.toUpperCase()}</div>
      </div>
    `;
          })
          .join("");
      }
      function openPicker(slot) {
        pickingSlot = slot;
        const lbl = document.getElementById("picker-label");
        lbl.textContent = `SELECT TITAN ${slot}`;
        lbl.className = `pick-lbl p${slot}`;
        const picker = document.getElementById("sim-picker");
        picker.classList.add("show");
        picker.className = `sim-picker show${slot === 2 ? " pick2" : ""}`;
        document.getElementById("pick-search").value = "";
        renderPickGrid();
        picker.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
      function filterPicker() {
        renderPickGrid(document.getElementById("pick-search").value);
      }

      function selectTitan(id) {
        const t = TITANS.find((x) => x.id === id);
        picks[pickingSlot - 1] = t;
        const slot = document.getElementById(`slot${pickingSlot}`);
        // Hide placeholder, show content
        slot.querySelector(".sim-slot-ph-icon").style.display = "none";
        document.getElementById(`slot${pickingSlot}-ph`).style.display = "none";
        const content = document.getElementById(`slot${pickingSlot}-content`);
        content.innerHTML = slotContent(t, pickingSlot);
        content.style.display = "block";
        // Accent the slot
        slot.className = pickingSlot === 1 ? "sim-slot sel" : "sim-slot sel2";
        document.getElementById("sim-picker").classList.remove("show");
        if (picks[0] && picks[1])
          document.getElementById("fight-btn").disabled = false;
      }

      // ── Combat log builder ──
      function buildCombatLog(a, b, aS, bS) {
        const lines = [];
        const push = (txt, cls = "") => lines.push({ txt, cls });
        push(
          `[MONARCH INTEL] Engagement detected. ${activeArena.emoji} Zone: ${activeArena.name.toUpperCase()}`,
          "",
        );
        push(
          `[BIOMETRIC LOCK] Subject Alpha: ${a.name} (${a.threat.toUpperCase()}-class)`,
          "",
        );
        push(
          `[BIOMETRIC LOCK] Subject Beta: ${b.name} (${b.threat.toUpperCase()}-class)`,
          "",
        );
        push(`[SIMULATION] Initiating combat sequence...`, "");
        // Trade blows
        const rounds = 5;
        let aHP = 100,
          bHP = 100;
        for (let i = 0; i < rounds; i++) {
          const aDmg = Math.round(
            ((aS.power * 0.4 + aS.speed * 0.2) * (0.8 + Math.random() * 0.4)) /
              20,
          );
          const bDmg = Math.round(
            ((bS.power * 0.4 + bS.speed * 0.2) * (0.8 + Math.random() * 0.4)) /
              20,
          );
          bHP -= aDmg;
          aHP -= bDmg;
          // A attacks
          const aPow =
            a.powers[Math.floor(Math.random() * Math.min(a.powers.length, 4))];
          push(
            `[T+${(i + 1) * 2}h] ${a.name} deploys ${aPow.toUpperCase()} — Impact: ${aDmg} damage units`,
            "hit",
          );
          if (bS.resilience > 65 && Math.random() > 0.5) {
            push(
              `[T+${(i + 1) * 2}h] ${b.name} PARTIAL BLOCK — Kinetic absorption registered`,
              "block",
            );
          }
          // B counterattacks
          const bPow =
            b.powers[Math.floor(Math.random() * Math.min(b.powers.length, 4))];
          push(
            `[T+${(i + 1) * 2}h] ${b.name} retaliates — ${bPow.toUpperCase()} — Impact: ${bDmg} damage units`,
            "hit",
          );
          if (aS.resilience > 65 && Math.random() > 0.6) {
            push(
              `[T+${(i + 1) * 2}h] ${a.name} PARTIAL BLOCK — Regenerative systems engaged`,
              "block",
            );
          }
          // Critical event on certain rounds
          if (i === 2) {
            const leading = aHP > bHP ? a : b;
            push(
              `[CRITICAL] ${leading.name} seizes tactical advantage — OMEGA-tier output detected`,
              "crit",
            );
          }
        }
        // Environmental note
        if (a.tags && b.tags) {
          const aBuff = a.tags.some((tag) =>
            activeArena.buff.tags.includes(tag),
          );
          const bBuff = b.tags.some((tag) =>
            activeArena.buff.tags.includes(tag),
          );
          if (aBuff)
            push(
              `[ENV] ${activeArena.name} terrain advantage: ${a.name} stat amplification ×${activeArena.buff.mult}`,
              "block",
            );
          else if (bBuff)
            push(
              `[ENV] ${activeArena.name} terrain advantage: ${b.name} stat amplification ×${activeArena.buff.mult}`,
              "block",
            );
        }
        push(`[MONARCH] Computing final engagement matrix...`, "");
        return lines;
      }

      // ── Log animator ──
      function animateCombatLog(lines, onComplete) {
        const body = document.getElementById("clog-body");
        body.innerHTML = "";
        document.getElementById("combat-log-wrap").classList.add("show");
        document
          .getElementById("combat-log-wrap")
          .scrollIntoView({ behavior: "smooth", block: "nearest" });
        let i = 0;
        const interval = setInterval(() => {
          if (i >= lines.length) {
            clearInterval(interval);
            setTimeout(onComplete, 400);
            return;
          }
          const { txt, cls } = lines[i];
          const div = document.createElement("div");
          div.className = `clog-line ${cls}`;
          div.textContent = `> ${txt}`;
          body.appendChild(div);
          requestAnimationFrame(() => div.classList.add("in"));
          // Auto-scroll log
          body.scrollTop = body.scrollHeight;
          i++;
        }, 320);
      }

      // ── Radar chart drawer ──
      function drawRadar(aStats, bStats, aName, bName) {
        const canvas = document.getElementById("radar-canvas");
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        const cx = 100,
          cy = 105,
          r = 75;
        const labels = ["POWER", "SIZE", "RESIL", "SPEED", "AGGR"];
        const keys = ["power", "size", "resilience", "speed", "aggression"];
        const n = keys.length;
        ctx.clearRect(0, 0, 200, 200);
        // Grid rings
        for (let ring = 1; ring <= 4; ring++) {
          ctx.beginPath();
          for (let j = 0; j < n; j++) {
            const angle = (j / n) * Math.PI * 2 - Math.PI / 2;
            const pr = (r * ring) / 4;
            const x = cx + Math.cos(angle) * pr;
            const y = cy + Math.sin(angle) * pr;
            j === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
          }
          ctx.closePath();
          ctx.strokeStyle = "rgba(21,37,53,0.9)";
          ctx.lineWidth = 1;
          ctx.stroke();
        }
        // Spokes
        for (let j = 0; j < n; j++) {
          const angle = (j / n) * Math.PI * 2 - Math.PI / 2;
          ctx.beginPath();
          ctx.moveTo(cx, cy);
          ctx.lineTo(cx + Math.cos(angle) * r, cy + Math.sin(angle) * r);
          ctx.strokeStyle = "rgba(42,80,112,0.7)";
          ctx.lineWidth = 1;
          ctx.stroke();
          // Labels
          const lx = cx + Math.cos(angle) * (r + 14);
          const ly = cy + Math.sin(angle) * (r + 14);
          ctx.font = "7px Share Tech Mono";
          ctx.fillStyle = "#4a6878";
          ctx.textAlign = "center";
          ctx.textBaseline = "middle";
          ctx.fillText(labels[j], lx, ly);
        }
        // Draw polygon for titan A (green)
        function drawPoly(stats, color) {
          ctx.beginPath();
          for (let j = 0; j < n; j++) {
            const angle = (j / n) * Math.PI * 2 - Math.PI / 2;
            const val = (stats[keys[j]] || 0) / 100;
            const x = cx + Math.cos(angle) * r * val;
            const y = cy + Math.sin(angle) * r * val;
            j === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
          }
          ctx.closePath();
          ctx.fillStyle = color + "22";
          ctx.fill();
          ctx.strokeStyle = color;
          ctx.lineWidth = 1.5;
          ctx.stroke();
        }
        drawPoly(aStats, "#00ff88");
        drawPoly(bStats, "#ff4d00");
        // Legend
        ctx.font = "8px Share Tech Mono";
        ctx.fillStyle = "#00ff88";
        ctx.textAlign = "left";
        ctx.fillText(`▶ ${aName.substring(0, 10)}`, 4, 190);
        ctx.fillStyle = "#ff4d00";
        ctx.textAlign = "right";
        ctx.fillText(`${bName.substring(0, 10)} ◀`, 196, 190);
      }

      // ── Main battle runner ──
      function showBattleResults(a, b, arena, isInstant) {
        document.getElementById("fight-btn").disabled = true;
        document.getElementById("fight-btn").textContent = "SIMULATING...";
        if (!isInstant) document.getElementById("fight-btn").classList.add("running");

        const aStats = scoreTitan(a, arena);
        const bStats = scoreTitan(b, arena);
        const totalA = Object.values(aStats).reduce((s, v) => s + v, 0);
        const totalB = Object.values(bStats).reduce((s, v) => s + v, 0);
        const winner = totalA >= totalB ? a : b;
        const loser = totalA >= totalB ? b : a;
        const totalWin = Math.max(totalA, totalB);
        const totalLose = Math.min(totalA, totalB);
        const winPct = Math.round((totalWin / (totalWin + totalLose)) * 100);
        const losePct = 100 - winPct;
        const margin = totalA - totalB;
        const closeness =
          Math.abs(margin) < 40
            ? "an extremely close engagement — outcome uncertain in the field"
            : "a decisive tactical victory";
        const analysis = `Monarch Combat Assessment [${arena.name}]: Based on 5-axis biometric evaluation and environmental modifiers, ${winner.name} achieves tactical superiority over ${loser.name}. Primary advantage: ${winner.powers[0].toLowerCase()} combined with ${winner.threat.toLowerCase()}-tier threat classification. ${loser.name}'s ${loser.powers[0].toLowerCase()} represents the primary counter-measure. This constitutes ${closeness}. Monarch recommendation: establish 30km exclusion zone. Evacuation protocols in effect.`;
        
        const logLines = buildCombatLog(a, b, aStats, bStats);
        document.getElementById("sim-result").classList.remove("show");

        const fillResults = () => {
          const wLine = document.createElement("div");
          wLine.className = "clog-line win in";
          wLine.textContent = `> [RESULT] VICTOR CONFIRMED: ${winner.name.toUpperCase()} — WIN PROBABILITY ${winPct}%`;
          document.getElementById("clog-body").appendChild(wLine);

          document.getElementById("res-we").textContent = winner.emoji;
          document.getElementById("res-wn").textContent = winner.name.toUpperCase();
          document.getElementById("res-analysis").textContent = analysis;

          const isAWinner = winner.id === a.id;
          document.getElementById("prob-name-a").textContent = a.name;
          document.getElementById("prob-name-b").textContent = b.name;
          const pctA = isAWinner ? winPct : losePct;
          const pctB = isAWinner ? losePct : winPct;
          document.getElementById("prob-fill-a").style.width = pctA + "%";
          document.getElementById("prob-fill-b").style.width = pctB + "%";
          document.getElementById("prob-pct-a").textContent = pctA + "%";
          document.getElementById("prob-pct-b").textContent = pctB + "%";

          const statDefs = [
            { key: "power", label: "POWER OUTPUT" },
            { key: "size", label: "BIOMETRIC SIZE" },
            { key: "resilience", label: "RESILIENCE" },
            { key: "speed", label: "SPEED INDEX" },
            { key: "aggression", label: "AGGRESSION" },
          ];
          document.getElementById("stat-cmp").innerHTML = statDefs
            .map((s) => {
              const va = aStats[s.key], vb = bStats[s.key];
              const aWins = va >= vb, bWins = vb >= va;
              return `
          <div class="sc-row">
            <div class="sc-v l ${aWins ? "sc-win" : "sc-lose"}">${va}</div>
            <div class="sc-lbl">${s.label}</div>
            <div class="sc-v r ${bWins ? "sc-win" : "sc-lose"}">${vb}</div>
          </div>`;
            })
            .join("");

          drawRadar(aStats, bStats, a.name, b.name);
          
          if (!isInstant) {
            battleHistory.unshift({ winner, loser, winPct, arena, a, b });
            renderHistory();
          }

          document.getElementById("sim-result").classList.add("show");
          if (!isInstant) {
            document.getElementById("sim-result").scrollIntoView({ behavior: "smooth", block: "nearest" });
          }
          
          document.getElementById("fight-btn").disabled = false;
          document.getElementById("fight-btn").classList.remove("running");
          document.getElementById("fight-btn").textContent = "FIGHT";
        };

        if (isInstant) {
          const body = document.getElementById("clog-body");
          body.innerHTML = "";
          document.getElementById("combat-log-wrap").classList.add("show");
          logLines.forEach(l => {
             const div = document.createElement("div");
             div.className = `clog-line ${l.cls} in`;
             div.textContent = `> ${l.txt}`;
             body.appendChild(div);
          });
          fillResults();
        } else {
          animateCombatLog(logLines, () => {
            setTimeout(fillResults, 600);
          });
        }
      }

      function runBattle() {
        showBattleResults(picks[0], picks[1], activeArena, false);
      }

      // ── History renderer ──
      function renderHistory() {
        const hist = document.getElementById("battle-hist");
        const strip = document.getElementById("hist-strip");
        if (!battleHistory.length) {
          hist.style.display = "none";
          return;
        }
        hist.style.display = "block";
        strip.innerHTML = battleHistory
          .slice(0, 8)
          .map(
            (h, i) => `
    <div class="hist-item" onclick="replayHistory(${i})" title="Rematch: ${h.winner.name} vs ${h.loser.name}">
      <span>${h.arena.emoji}</span>
      <span class="hist-win">${h.winner.emoji} ${h.winner.name} <span style="opacity:0.7;font-size:0.9em">(${h.winPct}%)</span></span>
      <span class="hist-vs">VS</span>
      <span style="color:var(--muted)">${h.loser.emoji} ${h.loser.name}</span>
    </div>
  `,
          )
          .join("");
      }

      // ── Replay History ──
      // ── Replay History ──
      function replayHistory(idx) {
        const h = battleHistory[idx];
        if (!h) return;
        selectArena(h.arena.id);
        pickingSlot = 1;
        selectTitan(h.a.id);
        pickingSlot = 2;
        selectTitan(h.b.id);
        showBattleResults(h.a, h.b, h.arena, true);
        document.getElementById("page-battle").scrollIntoView({ behavior: "smooth", block: "start" });
      }

      // ── Reset ──
      function resetBattle() {
        picks = [null, null];
        [1, 2].forEach((i) => {
          const slot = document.getElementById(`slot${i}`);
          slot.className = "sim-slot";
          document.getElementById(`slot${i}-ph`).style.display = "";
          slot.querySelector(".sim-slot-ph-icon").style.display = "";
          document.getElementById(`slot${i}-content`).style.display = "none";
          document.getElementById(`slot${i}-content`).innerHTML = "";
        });
        document.getElementById("fight-btn").disabled = true;
        document.getElementById("fight-btn").textContent = "FIGHT";
        document.getElementById("fight-btn").classList.remove("running");
        document.getElementById("sim-result").classList.remove("show");
        document.getElementById("sim-picker").classList.remove("show");
        document.getElementById("combat-log-wrap").classList.remove("show");
        document.getElementById("clog-body").innerHTML = "";
      }

      renderPickGrid();

      // ═══════════════════════════════════════════════════
      //  TIMELINE
      // ═══════════════════════════════════════════════════
      let tlFilter = "all";
      const typeColors = {
        titan: "var(--threat-omega)",
        monarch: "var(--monarch)",
        hollowearth: "var(--sky)",
        human: "var(--nuclear)",
      };
      function filterTL(btn, type) {
        document
          .querySelectorAll("#page-timeline .tog")
          .forEach((b) => b.classList.remove("on"));
        btn.classList.add("on");
        tlFilter = type;
        renderTL();
      }
      function renderTL() {
        const data =
          tlFilter === "all"
            ? TIMELINE
            : TIMELINE.filter((e) => e.type === tlFilter);
        document.getElementById("tl-count").textContent =
          data.length + " EVENTS";
        document.getElementById("tl-wrap").innerHTML = data
          .map(
            (e) => `
    <div class="tlev">
      <div class="tlev-yr">${e.year}</div>
      <div class="tlev-card" style="border-left-color:${typeColors[e.type] || "var(--nuclear)"}">
        <div class="tlev-title">${e.title}</div>
        <div class="tlev-desc">${e.desc}</div>
        <div class="tlev-tags"><span class="ttag" style="border-color:${typeColors[e.type]};color:${typeColors[e.type]}">${e.type.toUpperCase()}</span></div>
      </div>
    </div>
  `,
          )
          .join("");
      }
      renderTL();

      // ═══════════════════════════════════════════════════
      //  SECTION ATTRIBUTIONS (Size Chart / Relations / Timeline)
      // ═══════════════════════════════════════════════════
      // These sections are editorial syntheses — no TMDB imagery
      const editorialSources = {
        data: ["wikizilla", "monarchintel"],
        image: [],
      };
      (function injectSectionAttribution() {
        const targets = [
          { id: "page-sizechart", countSel: ".sec-count" },
          { id: "page-relations", countSel: ".sec-count" },
          { id: "page-timeline", countSel: ".sec-count" },
        ];
        const attrHTML = getAttrHTML(editorialSources);
        if (!attrHTML) return;
        targets.forEach(({ id, countSel }) => {
          const el = document.querySelector(`#${id} ${countSel}`);
          if (el) el.insertAdjacentHTML("afterend", attrHTML);
        });
      })();

      // ═══════════════════════════════════════════════════
      //  KEYBOARD
      // ═══════════════════════════════════════════════════
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
      });
    </script>
  </body>
</html>
